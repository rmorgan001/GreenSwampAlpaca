@page "/monitorsettings"

@inject NavigationManager NavManager
@inject GreenSwamp.Alpaca.Server.Services.MonitorDisplayService MonitorDisplay
@inject MudBlazor.ISnackbar Snackbar

@using GreenSwamp.Alpaca.Settings.Models
@using GreenSwamp.Alpaca.Settings.Services
@using GreenSwamp.Alpaca.Server.Components.SettingsGroups
@inject IVersionedSettingsService SettingsService

<PageTitle>Monitor Settings</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true">Monitor</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
	Live monitor output. Filter settings saved to: <code>@SettingsService.MonitorSettingsPath</code>
</MudText>

<MudCard Class="mb-4">
	<MudCardHeader>
		<CardHeaderContent>
			<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
				<MudIcon Icon="@Icons.Material.Filled.Terminal" Color="Color.Primary" />
				<MudText Typo="Typo.h6">Monitor Records</MudText>
				<MudSpacer />
				<MudText Typo="Typo.caption" Color="Color.Secondary">@_lines.Count / @GreenSwamp.Alpaca.Server.Services.MonitorDisplayService.Capacity records</MudText>
			</MudStack>
		</CardHeaderContent>
		<CardHeaderActions>
			<MudTooltip Text="Clear display buffer" RootStyle="max-width:180px">
				<MudIconButton Icon="@Icons.Material.Filled.DeleteSweep" Color="Color.Warning"
							   Size="Size.Small" OnClick="ClearDisplay" />
			</MudTooltip>
		</CardHeaderActions>
	</MudCardHeader>
	<MudCardContent>
		<MudPaper Outlined="true" Class="pa-2" Style="overflow-y: auto; overflow-x: auto; height: 420px;">
			<pre style="margin: 0; font-family: monospace; font-size: 1.00rem; white-space: pre;">@_displayText</pre>
		</MudPaper>
	</MudCardContent>
	<MudCardActions>
		<MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
				   StartIcon="@Icons.Material.Filled.ContentCopy"
				   OnClick="CopyToClipboard">
			Copy to Clipboard
		</MudButton>
		<MudButton Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small"
				   StartIcon="@Icons.Material.Filled.Sync" OnClick="ReloadSettings" Class="ml-2">
			Reload Settings
		</MudButton>
		@if (_settings.FastMonitor)
		{
			<MudButton Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small"
					   StartIcon="@Icons.Material.Filled.Save" OnClick="WriteBufferAsync"
					   Disabled="_writingBuffer" Class="ml-2">
				@if (_writingBuffer)
				{
					<MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-1" />
				}
				Write Buffer to File
			</MudButton>
		}
	</MudCardActions>
</MudCard>

<MonitorLoggingSettingsCard IsDirty="_isDirty" IsLoading="_saving"
	OnPresetSelected="ApplyPreset"
	OnQuickActionTriggered="HandleQuickAction"
	OnSave="SaveSettings"
	OnReset="ResetToDefaults" />

@code {
	private GreenSwamp.Alpaca.Settings.Models.MonitorSettings _settings = new();
	private bool _saving;
	private bool _writingBuffer;
	private bool _isDirty;

	private IReadOnlyList<string> _lines = Array.Empty<string>();
	private string _displayText = string.Empty;

	[Inject] private IJSRuntime JS { get; set; } = default!;

	protected override void OnInitialized()
	{
		LoadSettings();
		SettingsService.MonitorSettingsChanged += OnSettingsChanged;
		MonitorDisplay.RecordsChanged += OnRecordsChanged;
		RefreshDisplay();
	}

	private void RefreshDisplay()
	{
		_lines = MonitorDisplay.GetSnapshot();
		_displayText = string.Join('\n', _lines);
	}

	private void ClearDisplay()
	{
		MonitorDisplay.Clear();
		RefreshDisplay();
	}

	private async Task CopyToClipboard()
	{
		try
		{
			await JS.InvokeVoidAsync("navigator.clipboard.writeText", _displayText);
			Snackbar.Add("Monitor records copied to clipboard.", MudBlazor.Severity.Success);
		}
		catch
		{
			Snackbar.Add("Copy failed — clipboard access may be blocked.", MudBlazor.Severity.Error);
		}
	}

	private void OnRecordsChanged(object? sender, EventArgs e)
	{
		InvokeAsync(() =>
		{
			RefreshDisplay();
			StateHasChanged();
		});
	}

	private void LoadSettings()
	{
		_settings = SettingsService.GetMonitorSettings();
		_isDirty = false;
	}

	private async Task SaveSettings()
	{
		_saving = true;

		try
		{
			await SettingsService.SaveMonitorSettingsAsync(_settings);
			GreenSwamp.Alpaca.Shared.MonitorLog.Load_Settings();
			GreenSwamp.Alpaca.Shared.Settings.Load();
			Snackbar.Add("Monitor settings saved successfully! Changes applied immediately.", MudBlazor.Severity.Success);
			_isDirty = false;
		}
		catch (Exception ex)
		{
			Snackbar.Add($"Error saving settings: {ex.Message}", MudBlazor.Severity.Error);
		}
		finally
		{
			_saving = false;
		}
	}

	/// <summary>
	/// Flushes the fast monitor ring buffer to a datetime-stamped file.
	/// </summary>
	private async Task WriteBufferAsync()
	{
		_writingBuffer = true;
		try
		{
			await Task.Run(() => GreenSwamp.Alpaca.Shared.MonitorQueue.WriteBuffer());
			Snackbar.Add($"Fast monitor buffer written to file at {DateTime.Now:HH:mm:ss}", MudBlazor.Severity.Success);
		}
		catch (Exception ex)
		{
			Snackbar.Add($"Error writing buffer: {ex.Message}", MudBlazor.Severity.Error);
		}
		finally
		{
			_writingBuffer = false;
		}
	}

	private void ResetToDefaults()
	{
		_settings = new GreenSwamp.Alpaca.Settings.Models.MonitorSettings();
		_isDirty = true;
		Snackbar.Add("Settings reset to defaults (not saved yet)", MudBlazor.Severity.Warning);
	}

	private void ReloadSettings()
	{
		LoadSettings();
		Snackbar.Add("Settings reloaded from file", MudBlazor.Severity.Info);
	}

	private void ApplyPreset(GreenSwamp.Alpaca.Settings.Models.MonitorSettings preset)
	{
		_settings = preset;
		_isDirty = true;

		string presetName;
		if (preset.Data && preset.Ui && preset.Other)
			presetName = "Development";
		else if (!preset.LogMonitor && !preset.Ui && !preset.Other)
			presetName = "Production";
		else if (preset.Driver && preset.Interface && preset.LogMonitor)
			presetName = "Troubleshooting";
		else
			presetName = "Profile Debug";
		Snackbar.Add($"{presetName} preset applied (not saved yet)", MudBlazor.Severity.Info);
	}

	private void HandleQuickAction(string actionName)
	{
		switch (actionName)
		{
			case "SelectAllDevices":
				_settings.ServerDevice = true;
				_settings.Telescope = true;
				_settings.Ui = true;
				Snackbar.Add("All devices selected", MudBlazor.Severity.Info);
				break;
			case "SelectAllCategories":
				_settings.Other = true;
				_settings.Driver = true;
				_settings.Interface = true;
				_settings.Server = true;
				_settings.Mount = true;
				_settings.Alignment = true;
				Snackbar.Add("All categories selected", MudBlazor.Severity.Info);
				break;
			case "SelectAllTypes":
				_settings.Information = true;
				_settings.Data = true;
				_settings.Warning = true;
				_settings.Error = true;
				_settings.Debug = true;
				Snackbar.Add("All types selected", MudBlazor.Severity.Info);
				break;
			case "ClearAllFilters":
				_settings.ServerDevice = false;
				_settings.Telescope = false;
				_settings.Ui = false;
				_settings.Other = false;
				_settings.Driver = false;
				_settings.Interface = false;
				_settings.Server = false;
				_settings.Mount = false;
				_settings.Alignment = false;
				_settings.Information = false;
				_settings.Data = false;
				_settings.Warning = false;
				_settings.Error = false;
				_settings.Debug = false;
				Snackbar.Add("All filters cleared", MudBlazor.Severity.Info);
				break;
		}

		_isDirty = true;
	}

	private void OnSettingsChanged(object? sender, GreenSwamp.Alpaca.Settings.Models.MonitorSettings newSettings)
	{
		// Skip when we triggered the save ourselves — the working copy is already current.
		// Replacing the reference would orphan the bound controls and break dirty detection.
		if (_saving) return;
		_settings = newSettings;
		_isDirty = false;
		InvokeAsync(StateHasChanged);
	}

	public void Dispose()
	{
		SettingsService.MonitorSettingsChanged -= OnSettingsChanged;
		MonitorDisplay.RecordsChanged -= OnRecordsChanged;
	}
}