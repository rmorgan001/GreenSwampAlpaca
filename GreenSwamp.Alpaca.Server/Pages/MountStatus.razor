@page "/mount-status"
@page "/mount-status/{DeviceNumber:int}"
@using GreenSwamp.Alpaca.Server.Components
@using GreenSwamp.Alpaca.Server.Services
@using GreenSwamp.Alpaca.Server.Models
@using GreenSwamp.Alpaca.MountControl
@using GreenSwamp.Alpaca.Settings.Services
@using GreenSwamp.Alpaca.Settings.Models
@using ASCOM.Common.DeviceInterfaces
@using System.Globalization
@inject TelescopeStateService StateService
@inject IVersionedSettingsService SettingsService
@implements IDisposable

<PageTitle>Mount Status</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true">Mount Status</MudText>

<MudTabs Rounded="true" Elevation="1" @bind-ActivePanelIndex="ActiveTabIndex" Class="mb-4 gs-tabs-no-transform">
    @foreach (var dn in MountRegistry.GetAllInstances().Select(kvp => kvp.Key).OrderBy(k => k))
    {
        <MudTabPanel Text="@TabLabel(dn)">
            @{
                var s = StateService.GetCurrentState(dn);
            }

            <MudGrid Spacing="3" Class="mt-1">

                @* -- Row 1: Position | Status --------------------------- *@

                <MudItem xs="12" md="6">
                    <MudPaper Elevation="0" Class="pa-3">
                        <MudText Typo="Typo.overline" Class="gs-panel-heading mb-2">Position</MudText>
                        <MudSimpleTable Dense="true" Elevation="0">
                            <tbody>
                                <tr>
                                    <td style="width:80px"><MudText Typo="Typo.caption" Color="Color.Primary">RA</MudText></td>
                                    <td><MudText Typo="Typo.body2" Class="gs-font-mono">@FormatHMS(s.RightAscension)</MudText></td>
                                </tr>
                                <tr>
                                    <td><MudText Typo="Typo.caption" Color="Color.Primary">Dec</MudText></td>
                                    <td><MudText Typo="Typo.body2" Class="gs-font-mono">@FormatDMS(s.Declination)</MudText></td>
                                </tr>
                                <tr>
                                    <td><MudText Typo="Typo.caption" Color="Color.Primary">Alt</MudText></td>
                                    <td><MudText Typo="Typo.body2" Class="gs-font-mono">@FormatDMS(s.Altitude)</MudText></td>
                                </tr>
                                <tr>
                                    <td><MudText Typo="Typo.caption" Color="Color.Primary">Az</MudText></td>
                                    <td><MudText Typo="Typo.body2" Class="gs-font-mono">@FormatDMS(s.Azimuth)</MudText></td>
                                </tr>
                                <tr>
                                    <td><MudText Typo="Typo.caption" Color="Color.Primary">LHA</MudText></td>
                                    <td><MudText Typo="Typo.body2" Class="gs-font-mono">@FormatHMS(s.LocalHourAngle)</MudText></td>
                                </tr>
                                <tr>
                                    <td><MudText Typo="Typo.caption" Color="Color.Primary">Pier</MudText></td>
                                    <td><MudText Typo="Typo.body2" Class="gs-font-mono">@s.SideOfPier</MudText></td>
                                </tr>
                            </tbody>
                        </MudSimpleTable>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudPaper Elevation="0" Class="pa-3">
                        <MudText Typo="Typo.overline" Class="gs-panel-heading mb-2">Status</MudText>
                        <MudStack Spacing="1">
                            @StatusRowWithDetail("Mount Connected", s.IsMountRunning, s.ComPort, Color.Success)
                            @ActiveClientsRow(s.ConnectedClientCount)
                            @StatusRow("Slewing",           s.Slewing,           Color.Warning)
                            @StatusRow("Pulse Guiding", s.IsPulseGuidingRa || s.IsPulseGuidingDec, Color.Warning)
                            @StatusRow("Pulse Guide RA", s.IsPulseGuidingRa, Color.Warning)
                            @StatusRow("Pulse Guide Dec",   s.IsPulseGuidingDec, Color.Warning)
                            @StatusRowWithDetail("Tracking", s.Tracking, s.TrackingRate.ToString(), Color.Success)
                            @StatusRow("At Park",           s.AtPark,            Color.Info)
                            @StatusRow("At Home",           s.AtHome,            Color.Info)
                        </MudStack>
                    </MudPaper>
                </MudItem>

                @* -- Row 2: Axis Positions | Mount ----------------------- *@

                <MudItem xs="12" md="6">
                    <MudPaper Elevation="0" Class="pa-3">
                        <MudText Typo="Typo.overline" Class="gs-panel-heading mb-2">Axis Positions</MudText>
                        <MudSimpleTable Dense="true" Elevation="0">
                            <tbody>
                                <tr>
                                    <td style="width:90px"><MudText Typo="Typo.caption" Color="Color.Primary">Actual X</MudText></td>
                                    <td><MudText Typo="Typo.body2" Class="gs-font-mono">@FormatDegrees(s.ActualAxisX)</MudText></td>
                                </tr>
                                <tr>
                                    <td><MudText Typo="Typo.caption" Color="Color.Primary">Actual Y</MudText></td>
                                    <td><MudText Typo="Typo.body2" Class="gs-font-mono">@FormatDegrees(s.ActualAxisY)</MudText></td>
                                </tr>
                                <tr>
                                    <td><MudText Typo="Typo.caption" Color="Color.Primary">App X</MudText></td>
                                    <td><MudText Typo="Typo.body2" Class="gs-font-mono">@FormatDegrees(s.AppAxisX)</MudText></td>
                                </tr>
                                <tr>
                                    <td><MudText Typo="Typo.caption" Color="Color.Primary">App Y</MudText></td>
                                    <td><MudText Typo="Typo.body2" Class="gs-font-mono">@FormatDegrees(s.AppAxisY)</MudText></td>
                                </tr>
                                <tr>
                                    <td><MudText Typo="Typo.caption" Color="Color.Primary">Steps X</MudText></td>
                                    <td><MudText Typo="Typo.body2" Class="gs-font-mono">@s.Axis1Steps.ToString("N0")</MudText></td>
                                </tr>
                                <tr>
                                    <td><MudText Typo="Typo.caption" Color="Color.Primary">Steps Y</MudText></td>
                                    <td><MudText Typo="Typo.body2" Class="gs-font-mono">@s.Axis2Steps.ToString("N0")</MudText></td>
                                </tr>
                            </tbody>
                        </MudSimpleTable>
                    </MudPaper>
                </MudItem>

                @{
                    var mountSettings = _deviceSettings.GetValueOrDefault(dn);
                }
                <MudItem xs="12" md="6">
                    <MudPaper Elevation="0" Class="pa-3">
                        <MudText Typo="Typo.overline" Class="gs-panel-heading mb-2">Mount</MudText>
                        <MudSimpleTable Dense="true" Elevation="0">
                            <tbody>
                                <tr>
                                    <td style="width:80px"><MudText Typo="Typo.caption" Color="Color.Primary">Type</MudText></td>
                                    <td><MudText Typo="Typo.body2">@(mountSettings?.Mount ?? "—")</MudText></td>
                                </tr>
                                <tr>
                                    <td><MudText Typo="Typo.caption" Color="Color.Primary">Mode</MudText></td>
                                    <td><MudText Typo="Typo.body2">@(mountSettings?.AlignmentMode ?? "—")</MudText></td>
                                </tr>
                                <tr>
                                    <td><MudText Typo="Typo.caption" Color="Color.Primary">Local Date</MudText></td>
                                    <td><MudText Typo="Typo.body2" Class="gs-font-mono">@s.LocalDate.ToString("dd MMM yyyy  HH:mm:ss.ff", CultureInfo.CurrentCulture)</MudText></td>
                                </tr>
                            </tbody>
                        </MudSimpleTable>
                    </MudPaper>
                </MudItem>

                                @* -- Row 3: Axis Dials ---------------------------------- *@

                                <MudItem xs="12">
                                    <MudPaper Elevation="0" Class="pa-3">
                                        <MudText Typo="Typo.overline" Class="gs-panel-heading mb-2">Axis Dials</MudText>
                                        <MudStack Row="true" Justify="Justify.FlexStart" Spacing="6" Class="mt-1">
                                            <AxisDial Angle="@s.Azimuth" Label="Azimuth" Size="180" />
                                            <AxisDial Angle="@s.Altitude" Label="Altitude" Size="180" />
                                            <AxisDial Angle="@(s.RightAscension * 15)" Label="Right Ascension" 
                                                      DisplayUnits="DialDisplayUnits.Hours" Size="180" />
                                            <AxisDial Angle="@s.Declination" Label="Declination" Size="180" />
                                        </MudStack>
                                    </MudPaper>
                                </MudItem>

                                    </MudGrid>
                                </MudTabPanel>
                    }
</MudTabs>

@code {
    [Parameter] public int DeviceNumber { get; set; }

    private int ActiveTabIndex { get; set; }
    private List<AlpacaDevice> _alpacaDevices = [];
    private Dictionary<int, GreenSwamp.Alpaca.Settings.Models.SkySettings> _deviceSettings = new();

    protected override void OnInitialized()
    {
        _alpacaDevices = SettingsService.GetAlpacaDevices();
        _deviceSettings = SettingsService.GetAllDeviceSettings()
            .ToDictionary(d => d.DeviceNumber);
        StateService.StateChanged += OnStateChanged;
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        var keys = MountRegistry.GetAllInstances().Select(kvp => kvp.Key).OrderBy(k => k).ToList();
        var idx = keys.IndexOf(DeviceNumber);
        ActiveTabIndex = idx >= 0 ? idx : 0;
    }

    private void OnStateChanged(object? sender, EventArgs e) =>
        InvokeAsync(StateHasChanged);

    public void Dispose() =>
        StateService.StateChanged -= OnStateChanged;

    private string TabLabel(int deviceNumber)
    {
        var device = _alpacaDevices.FirstOrDefault(d => d.DeviceNumber == deviceNumber);
        return string.IsNullOrWhiteSpace(device?.DeviceName)
            ? $"Device {deviceNumber}"
            : device.DeviceName;
    }

    private RenderFragment BoolIcon(bool value, Color trueColor) => __builder =>
    {
        <MudIcon Icon="@(value ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                 Color="@(value ? trueColor : Color.Default)"
                 Size="Size.Small" />;
    };

    private RenderFragment StatusRow(string label, bool value, Color trueColor) => __builder =>
    {
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            @BoolIcon(value, trueColor)
            <MudText Typo="Typo.body2">@label</MudText>
        </MudStack>;
    };

    private RenderFragment StatusRowWithDetail(string label, bool value, string detail, Color trueColor) => __builder =>
    {
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            @BoolIcon(value, trueColor)
            <MudText Typo="Typo.body2">@label</MudText>
            @if (!string.IsNullOrWhiteSpace(detail))
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="gs-font-mono">@detail</MudText>
            }
        </MudStack>;
    };

    private RenderFragment ActiveClientsRow(int count) => __builder =>
    {
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudIcon Icon="@Icons.Material.Filled.People"
                     Color="@(count > 0 ? Color.Success : Color.Default)"
                     Size="Size.Small" />
            <MudText Typo="Typo.body2">Active clients</MudText>
            <MudText Typo="Typo.body2" Class="gs-font-mono">@count</MudText>
        </MudStack>;
    };

    private string FormatHMS(double hours)
    {
        if (double.IsNaN(hours) || double.IsInfinity(hours)) return "N/A";
        var sign = hours < 0 ? "-" : "+";
        hours = Math.Abs(hours);
        var h = (int)hours;
        var m = (int)((hours - h) * 60);
        var s = ((hours - h) * 60 - m) * 60;
        return $"{sign}{h:00}h {m:00}m {s:00.00}s";
    }

    private string FormatDMS(double degrees)
    {
        if (double.IsNaN(degrees) || double.IsInfinity(degrees)) return "N/A";
        var sign = degrees < 0 ? "-" : "+";
        degrees = Math.Abs(degrees);
        var d = (int)degrees;
        var m = (int)((degrees - d) * 60);
        var s = ((degrees - d) * 60 - m) * 60;
        return $"{sign}{d:00}° {m:00}' {s:00.00}\"";
    }

    private string FormatDegrees(double degrees)
    {
        if (double.IsNaN(degrees) || double.IsInfinity(degrees)) return "N/A";
        return $"{degrees:F4}°";
    }
}

