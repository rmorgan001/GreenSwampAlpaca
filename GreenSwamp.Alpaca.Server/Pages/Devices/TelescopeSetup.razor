@using GreenSwamp.Alpaca.MountControl
@using GreenSwamp.Alpaca.Shared

<PageTitle>Telescope Setup - Device @InstanceID</PageTitle>

@* Removed the redundant page subheading — main page title is handled elsewhere *@

@if (ASCOM.Alpaca.DeviceManager.Telescopes.ContainsKey(InstanceID))
{
    var instance = MountRegistry.GetInstance(InstanceID);
    if (instance != null)
    {
        var settings = instance.Settings;

        <MudGrid Spacing="3" Class="mb-4">

            @* ── Device Information ───────────────────────────────────── *@
            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader Style="padding:8px 16px 2px 16px; margin-bottom:6px;">
                        <CardHeaderContent>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Primary" />
                                <MudText Typo="Typo.body1">Device Information</MudText>
                            </MudStack>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent Style="padding-top:6px;">
                                <MudSimpleTable Dense="true" Hover="true" Class="ts-table">
                                    <tbody>
                                        <tr><th>Device Number</th><td><MudText>@InstanceID</MudText></td></tr>
                                        <tr><th>Device Name</th><td>@instance.DeviceName</td></tr>
                                        <tr><th>Mount Type</th><td>@settings.Mount</td></tr>
                                        <tr><th>Alignment Mode</th><td>@settings.AlignmentMode</td></tr>
                                        <tr>
                                            <th>Connection Status</th>
                                            <td>
                                                <MudText Color="@(instance.IsConnected ? Color.Success : Color.Default)">@(instance.IsConnected ? "Connected" : "Disconnected")</MudText>
                                            </td>
                                        </tr>
                                    </tbody>
                                </MudSimpleTable>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            @* ── Observatory Settings ─────────────────────────────────── *@
            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader Style="padding:8px 16px 2px 16px; margin-bottom:6px;">
                        <CardHeaderContent>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@Icons.Material.Filled.LocationOn" Color="Color.Success" />
                                <MudText Typo="Typo.body1">Observatory Settings</MudText>
                            </MudStack>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent Style="padding-top:6px;">
                        <MudSimpleTable Dense="true" Hover="true" Class="ts-table">
                            <tbody>
                                <tr><th>Latitude</th><td>@settings.Latitude.ToString("F6")°</td></tr>
                                <tr><th>Longitude</th><td>@settings.Longitude.ToString("F6")°</td></tr>
                                <tr><th>Elevation</th><td>@settings.Elevation m</td></tr>
                                <tr>
                                    <th>Refraction</th>
                                    <td>
                                        @if (settings.Refraction)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Check" Color="Color.Success" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Close" Color="Color.Default" />
                                        }
                                    </td>
                                </tr>
                            </tbody>
                        </MudSimpleTable>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            @* ── Serial Port Settings ─────────────────────────────────── *@
            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader Style="padding:8px 16px 2px 16px; margin-bottom:6px;">
                        <CardHeaderContent>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@Icons.Material.Filled.SettingsInputHdmi" Color="Color.Warning" />
                                <MudText Typo="Typo.body1">Serial Port Settings</MudText>
                            </MudStack>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent Style="padding-top:6px;">
                                <MudSimpleTable Dense="true" Hover="true" Class="ts-table">
                                    <tbody>
                                        <tr><th>Port</th><td>@settings.Port</td></tr>
                                        <tr><th>Baud Rate</th><td>@settings.BaudRate</td></tr>
                                        <tr><th>Data Bits</th><td>@settings.DataBits</td></tr>
                                        <tr><th>Read Timeout</th><td>@settings.ReadTimeout ms</td></tr>
                                    </tbody>
                                </MudSimpleTable>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            @* ── Tracking Settings ────────────────────────────────────── *@
            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader Style="padding:8px 16px 2px 16px; margin-bottom:6px;">
                        <CardHeaderContent>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@Icons.Material.Filled.TrackChanges" Color="Color.Info" />
                                <MudText Typo="Typo.body1">Tracking &amp; Guiding Settings</MudText>
                            </MudStack>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent Style="padding-top:6px;">
                                <MudSimpleTable Dense="true" Hover="true" Class="ts-table">
                                    <tbody>
                                        <tr>
                                            <th>Auto Track on Unpark</th>
                                            <td>
                                                @if (settings.AutoTrack)
                                                {
                                                    <MudIcon Icon="@Icons.Material.Filled.Check" Color="Color.Success" />
                                                }
                                                else
                                                {
                                                    <MudIcon Icon="@Icons.Material.Filled.Close" Color="Color.Default" />
                                                }
                                            </td>
                                        </tr>
                                        <tr><th>Tracking Rate</th><td>@settings.TrackingRate</td></tr>
                                        <tr><th>Sidereal Rate</th><td>@settings.SiderealRate.ToString("F7")"/sec</td></tr>
                                        @* Refraction moved to Observatory Settings *@
                                        <tr><th>Min Pulse RA</th><td>@settings.MinPulseRa ms</td></tr>
                                        <tr><th>Min Pulse Dec</th><td>@settings.MinPulseDec ms</td></tr>
                                    </tbody>
                                </MudSimpleTable>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            @* Row 3: Mount Settings and Telescope Optics ─────────────── *@
            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader Style="padding:8px 16px 2px 16px; margin-bottom:6px;">
                        <CardHeaderContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@Icons.Material.Filled.Tune" />
                                <MudText Typo="Typo.h6">Mount Settings</MudText>
                            </MudStack>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent Style="padding-top:6px;">
                                <MudSimpleTable Dense="true" Hover="true" Class="ts-table">
                            <tbody>
                                <tr><th>RA Backlash</th><td>@settings.RaBacklash</td></tr>
                                <tr><th>Dec Backlash</th><td>@settings.DecBacklash</td></tr>
                                <tr><th>Encoders</th><td>@if (settings.Encoders) { <MudIcon Icon="@Icons.Material.Filled.Check" Color="Color.Success" /> } else { <MudIcon Icon="@Icons.Material.Filled.Close" Color="Color.Default" /> }</td></tr>
                                <tr><th>Allow Advanced Commands</th><td>@if (settings.AllowAdvancedCommandSet) { <MudIcon Icon="@Icons.Material.Filled.Check" Color="Color.Success" /> } else { <MudIcon Icon="@Icons.Material.Filled.Close" Color="Color.Default" /> }</td></tr>
                            </tbody>
                        </MudSimpleTable>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader Style="padding:8px 16px 2px 16px; margin-bottom:6px;">
                        <CardHeaderContent>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@Icons.Material.Filled.Visibility" />
                                <MudText Typo="Typo.body1">Telescope Optics</MudText>
                            </MudStack>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent Style="padding-top:6px;">
                                <MudSimpleTable Dense="true" Hover="true" Class="ts-table">
                            <tbody>
                                <tr><th>Aperture Diameter</th><td>@settings.ApertureDiameter m</td></tr>
                                <tr><th>Aperture Area</th><td>@settings.ApertureArea m²</td></tr>
                                <tr><th>Focal Length</th><td>@settings.FocalLength m</td></tr>
                            </tbody>
                        </MudSimpleTable>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>

        @* Profile message and Back button removed per UI cleanup request *@
    }
    else
    {
        <MudAlert Severity="Severity.Error" Class="mb-3">
            <MudText Typo="Typo.h6">Device Instance Not Found</MudText>
            Device @InstanceID is registered but has no Mount instance. This may indicate a configuration error.
        </MudAlert>
        <MudButton Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.ArrowBack"
                   Href="/device-manager">Back to Device Manager</MudButton>
    }
}
else
{
    <MudAlert Severity="Severity.Warning" Class="mb-3">
        <MudText Typo="Typo.h6">Device Not Found</MudText>
        Device @InstanceID does not exist in the system. Please return to the Device Manager to see available devices.
    </MudAlert>
    <MudButton Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.ArrowBack"
               Href="/device-manager">Back to Device Manager</MudButton>
}

@code {
    [Parameter]
    public int InstanceID { get; set; }
}
