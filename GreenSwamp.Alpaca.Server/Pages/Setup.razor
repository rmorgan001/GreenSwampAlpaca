@page "/setup"

@inject NavigationManager NavManager
@inject GreenSwamp.Alpaca.Settings.Services.IVersionedSettingsService SettingsService
@inject MudBlazor.ISnackbar Snackbar

@using ASCOM.Common.Interfaces
@using ASCOM.Alpaca

<PageTitle>Server Settings</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true">Server Settings</MudText>
<MudText Typo="Typo.caption" Class="mb-3">Version: @Program.ServerVersion</MudText>

<MudGrid Spacing="3">

    @* ── Network ─────────────────────────────────────────────────────────── *@
    <MudItem xs="12" md="6">
        <MudCard Elevation="1" Style="height:100%">
            <MudCardHeader>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudIcon Icon="@Icons.Material.Filled.Lan" Size="Size.Small" Color="Color.Success" />
                    <MudText Typo="Typo.subtitle2">Network</MudText>
                </MudStack>
            </MudCardHeader>
            <MudCardContent>
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="8">
                        <MudStack Spacing="2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudTextField @bind-Value="Location" Label="Server Location"
                                              Variant="Variant.Filled" Margin="Margin.Dense" Style="flex:1" />
                                <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Describes where this server is physically located — shown in the Alpaca discovery response." Placement="Placement.Right" Arrow="true">
                                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Default" />
                                </MudTooltip>
                            </MudStack>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudNumericField T="UInt16" @bind-Value="ServerPort" Label="Alpaca Port"
                                                 Min="1" Max="65535" Variant="Variant.Filled" Margin="Margin.Dense" Style="max-width:180px;" />
                                <MudTooltip Inline="false" RootStyle="max-width:260px" Text="TCP port the Alpaca server listens on. Requires server restart to take effect." Placement="Placement.Right" Arrow="true">
                                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Default" />
                                </MudTooltip>
                            </MudStack>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudCheckBox @bind-Value="RemoteAccess" Label="Allow Remote Access" Dense="true" Color="Color.Primary" />
                                <MudTooltip Inline="false" RootStyle="max-width:260px" Text="When off, the server binds to localhost only and is not reachable from other machines on the network." Placement="Placement.Right" Arrow="true">
                                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Default" />
                                </MudTooltip>
                            </MudStack>

                            @* Discovery controls moved into Network card as requested *@
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudCheckBox @bind-Value="Discovery" Label="Allow Discovery" Dense="true" Color="Color.Primary" />
                                <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Enables Alpaca UDP discovery so ASCOM clients can find this server automatically." Placement="Placement.Right" Arrow="true">
                                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Default" />
                                </MudTooltip>
                            </MudStack>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudCheckBox @bind-Value="LocalHostOnlyOnHost" Label="Respond to localhost on loopback only" Dense="true" Color="Color.Primary" />
                                <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Limits discovery responses to clients on the same machine only." Placement="Placement.Right" Arrow="true">
                                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Default" />
                                </MudTooltip>
                            </MudStack>
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudPaper Class="pa-4" Style="height:100%; display:flex; align-items:flex-start;">
                            <div style="width:100%">
                                <MudText Typo="Typo.subtitle2" Class="mb-2">Server Addresses</MudText>
                                @if (_config.AllowRemoteAccess)
                                {
                                    <MudStack Spacing="0">
                                        @try
                                        {
                                            @foreach (var address in ASCOM.Alpaca.DiscoveryManager.AdapterAddress)
                                            {
                                                <MudText Typo="Typo.caption">@address</MudText>
                                            }
                                        }
                                        catch { }
                                    </MudStack>
                                }
                                else
                                {
                                    <MudText Typo="Typo.caption">localhost</MudText>
                                }
                            </div>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>
    </MudItem>

    @* ── Discovery / Runtime Configuration (merged) ────────────────────────── *@
    <MudItem xs="12" md="6">
        <MudCard Elevation="1" Style="height:100%">
            <MudCardHeader>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudIcon Icon="@Icons.Material.Filled.Tune" Size="Size.Small" Color="Color.Success" />
                    <MudText Typo="Typo.subtitle2">Runtime Configuration</MudText>
                </MudStack>
            </MudCardHeader>
            <MudCardContent>
                <MudStack Spacing="2">
                    @* Behaviour settings moved here *@
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudCheckBox @bind-Value="StartBrowser" Label="Open Browser on Start" Dense="true" Color="Color.Primary" />
                        <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Automatically opens the management UI in the default browser when the server starts." Placement="Placement.Right" Arrow="true">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Default" />
                        </MudTooltip>
                    </MudStack>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudCheckBox @bind-Value="StrictAPIMode" Label="Strict API Compliance" Dense="true" Color="Color.Primary" />
                        <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Enforces all required Alpaca response fields; recommended for production use." Placement="Placement.Right" Arrow="true">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Default" />
                        </MudTooltip>
                    </MudStack>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudCheckBox @bind-Value="PreventRemoteDisconnects" Label="Prevent Remote Disconnects" Dense="true" Color="Color.Primary" />
                        <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Ignores Disconnect commands sent by remote clients; protects a running session." Placement="Placement.Right" Arrow="true">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Default" />
                        </MudTooltip>
                    </MudStack>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudCheckBox @bind-Value="RunSwagger" Label="Run OpenAPI / Swagger" Dense="true" Color="Color.Primary" />
                        <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Hosts interactive API documentation at /swagger. Takes effect on next startup." Placement="Placement.Right" Arrow="true">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Default" />
                        </MudTooltip>
                    </MudStack>

                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>



    @* ── Security ─────────────────────────────────────────────────────────── *@
    <MudItem xs="12">
        <MudCard Elevation="1">
            <MudCardHeader><MudText Typo="Typo.subtitle2">Security</MudText></MudCardHeader>
            <MudCardContent>
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="3">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudCheckBox @bind-Value="RequireAuthorization" Label="Require Authorization" Dense="true" Color="Color.Primary" />
                            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Enables HTTP Basic authentication. All API clients must supply the credentials below." Placement="Placement.Right" Arrow="true">
                                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Default" />
                            </MudTooltip>
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12" sm="3">
                        <MudTextField @bind-Value="UserName" Label="User Name" Disabled="@DisableAuth" Variant="Variant.Filled" Margin="Margin.Dense" FullWidth="true" />
                    </MudItem>
                    <MudItem xs="12" sm="3">
                        <MudTextField @bind-Value="Password" Label="Password" InputType="InputType.Password" Disabled="@DisableAuth" Variant="Variant.Filled" Margin="Margin.Dense" FullWidth="true" />
                    </MudItem>
                    <MudItem xs="12" sm="3">
                        <MudTextField @bind-Value="Password2" Label="Repeat Password" InputType="InputType.Password" Disabled="@DisableAuth" Variant="Variant.Filled" Margin="Margin.Dense" FullWidth="true" />
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>
    </MudItem>

</MudGrid>

@* ── Footer action bar ────────────────────────────────────────────────────── *@
<MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-4" Spacing="3">
<MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(!_isDirty)" OnClick="SaveAllSettingsAsync">
    Save
</MudButton>
<MudSpacer />
<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
    <MudCheckBox @bind-Value="EnableShutdown" Label="Confirm shutdown" Dense="true" Color="Color.Primary" />
    <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Gracefully stops the server process. Use only when all mounts are parked and disconnected." Placement="Placement.Left" Arrow="true">
            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Default" />
        </MudTooltip>
    </MudStack>
    <MudButton Variant="Variant.Filled" Color="Color.Error" Disabled="@AllowShutdown" OnClick="Shutdown">
        Shutdown
    </MudButton>
</MudStack>

@code {

    // ── Snapshot record for dirty-state tracking ──────────────────────────────

    private record SettingsSnapshot(
        string   Location,
        UInt16   ServerPort,
        bool     RemoteAccess,
        bool     Discovery,
        bool     LocalHostOnlyOnHost,
        bool     StartBrowser,
        bool     StrictAPIMode,
        bool     PreventRemoteDisconnects,
        bool     RunSwagger,
        bool     RequireAuthorization,
        string   UserName
    );

    private GreenSwamp.Alpaca.Settings.Models.ServerConfig _config = new();
    private SettingsSnapshot _snapshot = new(string.Empty, 0, false, false, false, false, false, false, false, false, string.Empty);

    // ── Form-bound properties ─────────────────────────────────────────────────

    bool Discovery              { get; set; }
    bool StrictAPIMode          { get; set; }
    bool LocalHostOnlyOnHost    { get; set; }
    bool RemoteAccess           { get; set; }
    UInt16 ServerPort            { get; set; }
    bool StartBrowser           { get; set; }
    bool EnableShutdown         { get; set; } = false;
    string Location             { get; set; } = string.Empty;
    bool AllowShutdown          => !EnableShutdown;
    bool PreventRemoteDisconnects { get; set; }
    bool RequireAuthorization   { get; set; }
    bool DisableAuth            => !RequireAuthorization;
    string UserName             { get; set; } = string.Empty;
    string Password             { get; set; } = string.Empty;
    string Password2            { get; set; } = string.Empty;
    bool RunSwagger             { get; set; }

    // ── Dirty-state ───────────────────────────────────────────────────────────

    private bool _isDirty =>
        Location              != _snapshot.Location              ||
        ServerPort            != _snapshot.ServerPort            ||
        RemoteAccess          != _snapshot.RemoteAccess          ||
        Discovery             != _snapshot.Discovery             ||
        LocalHostOnlyOnHost   != _snapshot.LocalHostOnlyOnHost   ||
        StartBrowser          != _snapshot.StartBrowser          ||
        StrictAPIMode         != _snapshot.StrictAPIMode         ||
        PreventRemoteDisconnects != _snapshot.PreventRemoteDisconnects ||
        RunSwagger            != _snapshot.RunSwagger            ||
        RequireAuthorization  != _snapshot.RequireAuthorization  ||
        UserName              != _snapshot.UserName              ||
        !string.IsNullOrEmpty(Password);

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override void OnInitialized()
    {
        _config = SettingsService.GetServerConfig();
        LoadFormFromConfig();
    }

    private void LoadFormFromConfig()
    {
        Discovery                = _config.AllowDiscovery;
        StrictAPIMode            = _config.RunInStrictAlpacaMode;
        LocalHostOnlyOnHost      = _config.LocalRespondOnlyToLocalHost;
        RemoteAccess             = _config.AllowRemoteAccess;
        ServerPort               = _config.ServerPort;
        StartBrowser             = _config.AutoStartBrowser;
        Location                 = _config.Location;
        PreventRemoteDisconnects = _config.PreventRemoteDisconnects;
        RequireAuthorization     = _config.UseAuth;
        UserName                 = _config.UserName;
        RunSwagger               = _config.RunSwagger;

        CaptureSnapshot();
    }

    private void CaptureSnapshot() =>
        _snapshot = new SettingsSnapshot(
            Location, ServerPort, RemoteAccess, Discovery, LocalHostOnlyOnHost,
            StartBrowser, StrictAPIMode, PreventRemoteDisconnects,
            RunSwagger, RequireAuthorization, UserName
        );

    // ── Unified save ─────────────────────────────────────────────────────────

    async Task SaveAllSettingsAsync()
    {
        try
        {
            // Security validation
            if (RequireAuthorization)
            {
                if (string.IsNullOrEmpty(UserName))   { DisplayWarning("You must set a User Name"); return; }
                if (string.IsNullOrEmpty(Password))   { DisplayWarning("You must set a Password"); return; }
                if (Password != Password2)             { DisplayWarning("Passwords do not match"); return; }

                _config.UserName = UserName;
                _config.Password = Hash.GetStoragePassword(Password);
            }

            _config.AllowDiscovery              = Discovery;
            _config.RunInStrictAlpacaMode       = StrictAPIMode;
            _config.LocalRespondOnlyToLocalHost = LocalHostOnlyOnHost;
            _config.AllowRemoteAccess           = RemoteAccess;
            _config.ServerPort                  = ServerPort;
            _config.AutoStartBrowser            = StartBrowser;
            _config.Location                    = Location;
            _config.PreventRemoteDisconnects    = PreventRemoteDisconnects;
            _config.UseAuth                     = RequireAuthorization;
            _config.UserName                    = UserName;
            _config.RunSwagger                  = RunSwagger;

            await SettingsService.SaveServerConfigAsync(_config);

            Password  = string.Empty;
            Password2 = string.Empty;
            CaptureSnapshot();

            var msg = "Settings saved.";
            if (RemoteAccess != _snapshot.RemoteAccess || ServerPort != _snapshot.ServerPort)
                msg += " Restart the server to apply network changes.";

            DisplaySuccess(msg);

            if (RequireAuthorization && !string.IsNullOrEmpty(_config.UserName))
                NavManager.NavigateTo("/");
        }
        catch (Exception ex)
        {
            DisplayError(ex.Message);
        }
    }

    void Shutdown()
    {
        try
        {
            Program.Lifetime?.StopApplication();
        }
        catch (Exception ex)
        {
            DisplayError(ex.Message);
        }
    }

    public void DisplayError(string message)   => Snackbar.Add(message, MudBlazor.Severity.Error);
    public void DisplayWarning(string message) => Snackbar.Add(message, MudBlazor.Severity.Warning);
    public void DisplaySuccess(string message) => Snackbar.Add(message, MudBlazor.Severity.Success);
}
