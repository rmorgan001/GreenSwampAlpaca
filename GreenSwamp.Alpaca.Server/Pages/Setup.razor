@page "/setup"

@inject NavigationManager NavManager
@inject GreenSwamp.Alpaca.Settings.Services.IVersionedSettingsService SettingsService

@using ASCOM.Common.Interfaces
@using ASCOM.Alpaca

<fieldset>
    <legend>Server Settings</legend>

    <p>Server Version: @Program.ServerVersion</p>

    <label>Server Location: </label>
    <input type="text" style="width:21ch;" @bind="Location">

    <br />


    <label>Allow Remote Access:</label>
    <input type="checkbox" @bind="RemoteAccess">

    <br />

    <label>Server (Alpaca) Port:</label>
    <input type="number" @bind="ServerPort" min="1" max="65535" style="width:20ch;">

    <br />

    <label>Open Browser on Start:</label>
    <input type="checkbox" @bind="StartBrowser">

    <br />

    <label>Require Strict API Compliance:</label>
    <input type="checkbox" @bind="StrictAPIMode">

    <br />

    <button @onclick="SaveServerSettings" style="min-width:12ch; vertical-align:middle;">Save</button>

</fieldset>

<fieldset>
    <legend>Bound Addresses</legend>

    <table>
        <tr>
            <th>Addresses server is listening on.</th>
        </tr>

        @if (_config.AllowRemoteAccess)
        {
            try
            {
                @foreach (var address in ASCOM.Alpaca.DiscoveryManager.AdapterAddress)
                {
                    <tr>
                        <td>@address</td>
                    </tr>
                }
            }
            catch
            {

            }
        }
        else
        {
            <tr>
                <td>localhost</td>
            </tr>
        }
    </table>
</fieldset>

<fieldset>
    <legend>Driver Settings</legend>

    <br />

    <label>Prevent Disconnects:</label>
    <input type="checkbox" @bind="PreventRemoteDisconnects">

    <br />

    <button @onclick="SaveDriverSettings" style="min-width:12ch; vertical-align:middle;">Save</button>
</fieldset>

<fieldset>
    <legend>Alpaca Discovery Settings</legend>

    <br />

    <label>Allow Discovery:</label>
    <input type="checkbox" @bind="Discovery">

    <br />

    <label>Respond to localhost on loopback only:</label>
    <input type="checkbox" @bind="LocalHostOnlyOnHost">

    <br />

    <button @onclick="SaveDiscovery" style="min-width:12ch; vertical-align:middle;">Save</button>

</fieldset>

<fieldset>
    <legend>Security Settings</legend>

    <br />

    <label>Require Authorization:</label>
    <input type="checkbox" @bind="RequireAuthorization">

    <br />

    <label>User Name:</label>
    <input type="text" @bind="UserName" style="width:21ch;" disabled="@DisableAuth">

    <br />

    <label>Password:</label>
    <input type="password" @bind="Password" style="width:21ch;" disabled="@DisableAuth">

    <br />

    <label>Repeat:</label>
    <input type="password" @bind="Password2" style="width:21ch;" disabled="@DisableAuth">

    <br />

    <button @onclick="SaveSecuritySettings" style="min-width:12ch; vertical-align:middle;">Save</button>

</fieldset>

<fieldset>
    <legend>Log Settings</legend>
    <p>The logging system will log out at or above the specified level.</p>
    <label>Log Level:</label>
    <select @bind="LoggingLevel">
        <option value="@LogLevel.Verbose">Verbose</option>
        <option value="@LogLevel.Debug">Debug</option>
        <option value="@LogLevel.Information">Information</option>
        <option value="@LogLevel.Warning">Warning</option>
        <option value="@LogLevel.Error">Error</option>
        <option value="@LogLevel.Fatal">Fatal</option>
    </select>

    <br />

    <button @onclick="SaveLogSettings" style="min-width:12ch; vertical-align:middle;">Save</button>
</fieldset>

<fieldset>
    <legend>Run OpenAPI / Swagger</legend>
    <p>The OpenAPI / Swagger integration allows for the Alpaca API documentation to be shown by this server. It also allows calls to be made directly in the browser. Note that this will apply on the next time this driver runs.</p>

    <label>Run OpenAPI:</label>
    <input type="checkbox" @bind="RunSwagger">
    <br />
    <button @onclick="SaveSwaggerSettings" style="min-width:12ch; vertical-align:middle;">Save</button>

</fieldset>


<fieldset>
    <legend>Shutdown Driver</legend>
    <br />
    <span>Shutdown:</span>
    <input type="checkbox"
    @bind="EnableShutdown">
    <button @onclick="Shutdown" style="min-width:12ch; vertical-align:middle;" disabled="@AllowShutdown">Shutdown</button>
</fieldset>

@code {

    private GreenSwamp.Alpaca.Settings.Models.ServerConfig _config = new();

    // ── Form-bound properties ─────────────────────────────────────────────────

    bool Discovery { get; set; }
    bool StrictAPIMode { get; set; }
    bool LocalHostOnlyOnHost { get; set; }
    bool RemoteAccess { get; set; }
    UInt16 ServerPort { get; set; }
    bool StartBrowser { get; set; }
    bool EnableShutdown { get; set; } = false;
    string Location { get; set; } = string.Empty;
    bool AllowShutdown => !EnableShutdown;
    bool PreventRemoteDisconnects { get; set; }
    bool RequireAuthorization { get; set; }
    bool DisableAuth => !RequireAuthorization;
    string UserName { get; set; } = string.Empty;
    LogLevel LoggingLevel { get; set; }
    string Password { get; set; } = string.Empty;
    string Password2 { get; set; } = string.Empty;
    bool RunSwagger { get; set; }

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override void OnInitialized()
    {
        _config = SettingsService.GetServerConfig();
        LoadFormFromConfig();
    }

    private void LoadFormFromConfig()
    {
        Discovery           = _config.AllowDiscovery;
        StrictAPIMode       = _config.RunInStrictAlpacaMode;
        LocalHostOnlyOnHost = _config.LocalRespondOnlyToLocalHost;
        RemoteAccess        = _config.AllowRemoteAccess;
        ServerPort          = _config.ServerPort;
        StartBrowser        = _config.AutoStartBrowser;
        Location            = _config.Location;
        PreventRemoteDisconnects = _config.PreventRemoteDisconnects;
        RequireAuthorization = _config.UseAuth;
        UserName            = _config.UserName;
        RunSwagger          = _config.RunSwagger;

        if (Enum.TryParse<LogLevel>(_config.LoggingLevel, out var level))
            LoggingLevel = level;
        else
            LoggingLevel = LogLevel.Information;
    }

    // ── Save helpers ─────────────────────────────────────────────────────────

    private async Task ApplyAndSaveAsync()
    {
        _config.AllowDiscovery             = Discovery;
        _config.RunInStrictAlpacaMode      = StrictAPIMode;
        _config.LocalRespondOnlyToLocalHost = LocalHostOnlyOnHost;
        _config.AllowRemoteAccess          = RemoteAccess;
        _config.ServerPort                 = ServerPort;
        _config.AutoStartBrowser           = StartBrowser;
        _config.Location                   = Location;
        _config.PreventRemoteDisconnects   = PreventRemoteDisconnects;
        _config.UseAuth                    = RequireAuthorization;
        _config.UserName                   = UserName;
        _config.RunSwagger                 = RunSwagger;
        _config.LoggingLevel               = LoggingLevel.ToString();

        await SettingsService.SaveServerConfigAsync(_config);
    }

    // ── Event handlers ────────────────────────────────────────────────────────

    async Task SaveDiscovery()
    {
        try
        {
            await ApplyAndSaveAsync();
            DisplaySuccess("Discovery Settings Saved");
        }
        catch (Exception ex)
        {
            DisplayError(ex.Message);
        }
    }

    async Task SaveServerSettings()
    {
        try
        {
            await ApplyAndSaveAsync();
            DisplaySuccess("Server Settings Saved \u2014 restart the server to apply port/access changes.");
        }
        catch (Exception ex)
        {
            DisplayError(ex.Message);
        }
    }

    async Task SaveDriverSettings()
    {
        try
        {
            await ApplyAndSaveAsync();
            DisplaySuccess("Driver Settings Saved");
        }
        catch (Exception ex)
        {
            DisplayError(ex.Message);
        }
    }

    async Task SaveLogSettings()
    {
        try
        {
            _config.LoggingLevel = LoggingLevel.ToString();
            await SettingsService.SaveServerConfigAsync(_config);
            DisplaySuccess("Logging Settings Saved");
        }
        catch (Exception ex)
        {
            DisplayError(ex.Message);
        }
    }

    async Task SaveSecuritySettings()
    {
        try
        {
            if (RequireAuthorization)
            {
                if (string.IsNullOrEmpty(UserName))
                {
                    DisplayWarning("You must set a User Name");
                    return;
                }

                if (string.IsNullOrEmpty(Password))
                {
                    DisplayWarning("You must set a Password");
                    return;
                }

                if (Password != Password2)
                {
                    DisplayWarning("Passwords do not match");
                    return;
                }

                _config.UserName = UserName;
                _config.Password = Hash.GetStoragePassword(Password);
                _config.UseAuth  = true;

                await SettingsService.SaveServerConfigAsync(_config);
                NavManager.NavigateTo("/");
            }
            else
            {
                _config.UseAuth = false;
                await SettingsService.SaveServerConfigAsync(_config);
            }

            DisplaySuccess("Security Saved!");
        }
        catch (Exception ex)
        {
            DisplayError(ex.Message);
        }
    }

    async Task SaveSwaggerSettings()
    {
        try
        {
            _config.RunSwagger = RunSwagger;
            await SettingsService.SaveServerConfigAsync(_config);
            DisplaySuccess("Open API Settings saved!");
        }
        catch (Exception ex)
        {
            DisplayError(ex.Message);
        }
    }

    void Shutdown()
    {
        try
        {
            Program.Lifetime?.StopApplication();
        }
        catch (Exception ex)
        {
            DisplayError(ex.Message);
        }
    }

    public void DisplayError(string message) { }
    public void DisplayWarning(string message) { }
    public void DisplaySuccess(string message) { }
}