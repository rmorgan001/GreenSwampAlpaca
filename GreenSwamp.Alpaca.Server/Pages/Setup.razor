@page "/setup"

@inject NavigationManager NavManager
@inject GreenSwamp.Alpaca.Settings.Services.IVersionedSettingsService SettingsService

@using ASCOM.Common.Interfaces
@using ASCOM.Alpaca

<PageTitle>Server Settings</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true">Server Settings</MudText>

@if (!string.IsNullOrEmpty(_feedback))
{
    <MudAlert Severity="_feedbackSeverity" Dense="true" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="() => _feedback = string.Empty">
        @_feedback
    </MudAlert>
}

<MudStack Spacing="4">

    @* ── Server ───────────────────────────────────────────────────────────── *@
    <MudCard>
        <MudCardHeader><MudText Typo="Typo.subtitle1">Server</MudText></MudCardHeader>
        <MudCardContent>
            <MudText Typo="Typo.caption" Class="mb-2">Version: @Program.ServerVersion</MudText>
            <MudTextField @bind-Value="Location" Label="Server Location" Style="max-width:320px;" Class="mb-3" />
            <MudCheckBox @bind-Value="RemoteAccess" Label="Allow Remote Access" Class="mb-2" />
            <MudNumericField T="UInt16" @bind-Value="ServerPort" Label="Server (Alpaca) Port" Min="1" Max="65535" Style="max-width:200px;" Class="mb-3" />
            <MudCheckBox @bind-Value="StartBrowser" Label="Open Browser on Start" Class="mb-2" />
            <MudCheckBox @bind-Value="StrictAPIMode" Label="Require Strict API Compliance" />
        </MudCardContent>
        <MudCardActions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveServerSettings">Save</MudButton>
        </MudCardActions>
    </MudCard>

    @* ── Bound Addresses ─────────────────────────────────────────────────── *@
    <MudCard>
        <MudCardHeader><MudText Typo="Typo.subtitle1">Bound Addresses</MudText></MudCardHeader>
        <MudCardContent>
            @if (_config.AllowRemoteAccess)
            {
                try
                {
                    @foreach (var address in ASCOM.Alpaca.DiscoveryManager.AdapterAddress)
                    {
                        <MudText>@address</MudText>
                    }
                }
                catch { }
            }
            else
            {
                <MudText>localhost</MudText>
            }
        </MudCardContent>
    </MudCard>

    @* ── Driver ───────────────────────────────────────────────────────────── *@
    <MudCard>
        <MudCardHeader><MudText Typo="Typo.subtitle1">Driver Settings</MudText></MudCardHeader>
        <MudCardContent>
            <MudCheckBox @bind-Value="PreventRemoteDisconnects" Label="Prevent Disconnects" />
        </MudCardContent>
        <MudCardActions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveDriverSettings">Save</MudButton>
        </MudCardActions>
    </MudCard>

    @* ── Discovery ────────────────────────────────────────────────────────── *@
    <MudCard>
        <MudCardHeader><MudText Typo="Typo.subtitle1">Alpaca Discovery Settings</MudText></MudCardHeader>
        <MudCardContent>
            <MudCheckBox @bind-Value="Discovery" Label="Allow Discovery" Class="mb-2" />
            <MudCheckBox @bind-Value="LocalHostOnlyOnHost" Label="Respond to localhost on loopback only" />
        </MudCardContent>
        <MudCardActions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveDiscovery">Save</MudButton>
        </MudCardActions>
    </MudCard>

    @* ── Security ─────────────────────────────────────────────────────────── *@
    <MudCard>
        <MudCardHeader><MudText Typo="Typo.subtitle1">Security Settings</MudText></MudCardHeader>
        <MudCardContent>
            <MudCheckBox @bind-Value="RequireAuthorization" Label="Require Authorization" Class="mb-3" />
            <MudTextField @bind-Value="UserName" Label="User Name" Disabled="@DisableAuth" Style="max-width:280px;" Class="mb-3" />
            <MudTextField @bind-Value="Password" Label="Password" InputType="InputType.Password" Disabled="@DisableAuth" Style="max-width:280px;" Class="mb-3" />
            <MudTextField @bind-Value="Password2" Label="Repeat Password" InputType="InputType.Password" Disabled="@DisableAuth" Style="max-width:280px;" />
        </MudCardContent>
        <MudCardActions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveSecuritySettings">Save</MudButton>
        </MudCardActions>
    </MudCard>

    @* ── Log Level ────────────────────────────────────────────────────────── *@
    <MudCard>
        <MudCardHeader><MudText Typo="Typo.subtitle1">Log Settings</MudText></MudCardHeader>
        <MudCardContent>
            <MudText Typo="Typo.body2" Class="mb-3">The logging system will log at or above the specified level.</MudText>
            <MudSelect @bind-Value="LoggingLevel" Label="Log Level" Style="max-width:220px;">
                <MudSelectItem Value="@LogLevel.Verbose">Verbose</MudSelectItem>
                <MudSelectItem Value="@LogLevel.Debug">Debug</MudSelectItem>
                <MudSelectItem Value="@LogLevel.Information">Information</MudSelectItem>
                <MudSelectItem Value="@LogLevel.Warning">Warning</MudSelectItem>
                <MudSelectItem Value="@LogLevel.Error">Error</MudSelectItem>
                <MudSelectItem Value="@LogLevel.Fatal">Fatal</MudSelectItem>
            </MudSelect>
        </MudCardContent>
        <MudCardActions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveLogSettings">Save</MudButton>
        </MudCardActions>
    </MudCard>

    @* ── OpenAPI ──────────────────────────────────────────────────────────── *@
    <MudCard>
        <MudCardHeader><MudText Typo="Typo.subtitle1">OpenAPI / Swagger</MudText></MudCardHeader>
        <MudCardContent>
            <MudText Typo="Typo.body2" Class="mb-3">
                The OpenAPI / Swagger integration allows the Alpaca API documentation to be shown by this server
                and enables direct browser calls. Takes effect on next startup.
            </MudText>
            <MudCheckBox @bind-Value="RunSwagger" Label="Run OpenAPI" />
        </MudCardContent>
        <MudCardActions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveSwaggerSettings">Save</MudButton>
        </MudCardActions>
    </MudCard>

    @* ── Shutdown ─────────────────────────────────────────────────────────── *@
    <MudCard>
        <MudCardHeader><MudText Typo="Typo.subtitle1">Shutdown Driver</MudText></MudCardHeader>
        <MudCardContent>
            <MudCheckBox @bind-Value="EnableShutdown" Label="Confirm shutdown" />
        </MudCardContent>
        <MudCardActions>
            <MudButton Variant="Variant.Filled" Color="Color.Error" Disabled="@AllowShutdown" OnClick="Shutdown">
                Shutdown
            </MudButton>
        </MudCardActions>
    </MudCard>

</MudStack>

@code {

    private GreenSwamp.Alpaca.Settings.Models.ServerConfig _config = new();

    // ── Form-bound properties ─────────────────────────────────────────────────

    bool Discovery { get; set; }
    bool StrictAPIMode { get; set; }
    bool LocalHostOnlyOnHost { get; set; }
    bool RemoteAccess { get; set; }
    UInt16 ServerPort { get; set; }
    bool StartBrowser { get; set; }
    bool EnableShutdown { get; set; } = false;
    string Location { get; set; } = string.Empty;
    bool AllowShutdown => !EnableShutdown;
    bool PreventRemoteDisconnects { get; set; }
    bool RequireAuthorization { get; set; }
    bool DisableAuth => !RequireAuthorization;
    string UserName { get; set; } = string.Empty;
    LogLevel LoggingLevel { get; set; }
    string Password { get; set; } = string.Empty;
    string Password2 { get; set; } = string.Empty;
    bool RunSwagger { get; set; }

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override void OnInitialized()
    {
        _config = SettingsService.GetServerConfig();
        LoadFormFromConfig();
    }

    private void LoadFormFromConfig()
    {
        Discovery           = _config.AllowDiscovery;
        StrictAPIMode       = _config.RunInStrictAlpacaMode;
        LocalHostOnlyOnHost = _config.LocalRespondOnlyToLocalHost;
        RemoteAccess        = _config.AllowRemoteAccess;
        ServerPort          = _config.ServerPort;
        StartBrowser        = _config.AutoStartBrowser;
        Location            = _config.Location;
        PreventRemoteDisconnects = _config.PreventRemoteDisconnects;
        RequireAuthorization = _config.UseAuth;
        UserName            = _config.UserName;
        RunSwagger          = _config.RunSwagger;

        if (Enum.TryParse<LogLevel>(_config.LoggingLevel, out var level))
            LoggingLevel = level;
        else
            LoggingLevel = LogLevel.Information;
    }

    // ── Save helpers ─────────────────────────────────────────────────────────

    private async Task ApplyAndSaveAsync()
    {
        _config.AllowDiscovery             = Discovery;
        _config.RunInStrictAlpacaMode      = StrictAPIMode;
        _config.LocalRespondOnlyToLocalHost = LocalHostOnlyOnHost;
        _config.AllowRemoteAccess          = RemoteAccess;
        _config.ServerPort                 = ServerPort;
        _config.AutoStartBrowser           = StartBrowser;
        _config.Location                   = Location;
        _config.PreventRemoteDisconnects   = PreventRemoteDisconnects;
        _config.UseAuth                    = RequireAuthorization;
        _config.UserName                   = UserName;
        _config.RunSwagger                 = RunSwagger;
        _config.LoggingLevel               = LoggingLevel.ToString();

        await SettingsService.SaveServerConfigAsync(_config);
    }

    // ── Event handlers ────────────────────────────────────────────────────────

    async Task SaveDiscovery()
    {
        try
        {
            await ApplyAndSaveAsync();
            DisplaySuccess("Discovery Settings Saved");
        }
        catch (Exception ex)
        {
            DisplayError(ex.Message);
        }
    }

    async Task SaveServerSettings()
    {
        try
        {
            await ApplyAndSaveAsync();
            DisplaySuccess("Server Settings Saved \u2014 restart the server to apply port/access changes.");
        }
        catch (Exception ex)
        {
            DisplayError(ex.Message);
        }
    }

    async Task SaveDriverSettings()
    {
        try
        {
            await ApplyAndSaveAsync();
            DisplaySuccess("Driver Settings Saved");
        }
        catch (Exception ex)
        {
            DisplayError(ex.Message);
        }
    }

    async Task SaveLogSettings()
    {
        try
        {
            _config.LoggingLevel = LoggingLevel.ToString();
            await SettingsService.SaveServerConfigAsync(_config);
            DisplaySuccess("Logging Settings Saved");
        }
        catch (Exception ex)
        {
            DisplayError(ex.Message);
        }
    }

    async Task SaveSecuritySettings()
    {
        try
        {
            if (RequireAuthorization)
            {
                if (string.IsNullOrEmpty(UserName))
                {
                    DisplayWarning("You must set a User Name");
                    return;
                }

                if (string.IsNullOrEmpty(Password))
                {
                    DisplayWarning("You must set a Password");
                    return;
                }

                if (Password != Password2)
                {
                    DisplayWarning("Passwords do not match");
                    return;
                }

                _config.UserName = UserName;
                _config.Password = Hash.GetStoragePassword(Password);
                _config.UseAuth  = true;

                await SettingsService.SaveServerConfigAsync(_config);
                NavManager.NavigateTo("/");
            }
            else
            {
                _config.UseAuth = false;
                await SettingsService.SaveServerConfigAsync(_config);
            }

            DisplaySuccess("Security Saved!");
        }
        catch (Exception ex)
        {
            DisplayError(ex.Message);
        }
    }

    async Task SaveSwaggerSettings()
    {
        try
        {
            _config.RunSwagger = RunSwagger;
            await SettingsService.SaveServerConfigAsync(_config);
            DisplaySuccess("Open API Settings saved!");
        }
        catch (Exception ex)
        {
            DisplayError(ex.Message);
        }
    }

    void Shutdown()
    {
        try
        {
            Program.Lifetime?.StopApplication();
        }
        catch (Exception ex)
        {
            DisplayError(ex.Message);
        }
    }

    public void DisplayError(string message)   { _feedback = message; _feedbackSeverity = Severity.Error;   }
    public void DisplayWarning(string message) { _feedback = message; _feedbackSeverity = Severity.Warning; }
    public void DisplaySuccess(string message) { _feedback = message; _feedbackSeverity = Severity.Success; }

    private string _feedback = string.Empty;
    private Severity _feedbackSeverity = Severity.Normal;
}