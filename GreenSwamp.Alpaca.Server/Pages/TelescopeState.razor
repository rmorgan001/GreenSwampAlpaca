@page "/telescope-state"
@page "/telescope-state/{DeviceNumber:int}"
@using GreenSwamp.Alpaca.Server.Services
@using GreenSwamp.Alpaca.Server.Models
@using GreenSwamp.Alpaca.MountControl
@using ASCOM.Common.DeviceInterfaces
@inject TelescopeStateService StateService
@implements IDisposable

<PageTitle>Telescope State</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true">Telescope Device State</MudText>

<MudButtonGroup Variant="Variant.Outlined" Size="Size.Small" Class="mb-4">
    @foreach (var kvp in MountRegistry.GetAllInstances())
    {
        var dn = kvp.Key;
        <MudButton Color="@(dn == DeviceNumber ? Color.Primary : Color.Default)"
                   Href="@($"/telescope-state/{dn}")">Device @dn</MudButton>
    }
</MudButtonGroup>

<MudCard Class="mb-4">
    <MudCardHeader><MudText Typo="Typo.subtitle1">Connection &amp; Status</MudText></MudCardHeader>
    <MudCardContent>
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Mount Running</MudText><MudText Color="@StatusColor(_state.IsMountRunning)">@_state.IsMountRunning</MudText></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Slewing</MudText><MudText Color="@StatusColor(_state.Slewing)">@_state.Slewing</MudText></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Tracking</MudText><MudText Color="@StatusColor(_state.Tracking)">@_state.Tracking</MudText></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">At Park</MudText><MudText>@_state.AtPark</MudText></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">At Home</MudText><MudText>@_state.AtHome</MudText></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Slew State</MudText><MudText>@_state.SlewState</MudText></MudItem>
        </MudGrid>
    </MudCardContent>
</MudCard>

<MudCard Class="mb-4">
    <MudCardHeader><MudText Typo="Typo.subtitle1">Current Position (ASCOM)</MudText></MudCardHeader>
    <MudCardContent>
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Right Ascension</MudText><MudText>@FormatHMS(_state.RightAscension)</MudText></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Declination</MudText><MudText>@FormatDMS(_state.Declination)</MudText></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Altitude</MudText><MudText>@FormatDegrees(_state.Altitude)</MudText></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Azimuth</MudText><MudText>@FormatDegrees(_state.Azimuth)</MudText></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Side of Pier</MudText><MudText>@_state.SideOfPier</MudText></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Local Hour Angle</MudText><MudText>@FormatHMS(_state.LocalHourAngle)</MudText></MudItem>
        </MudGrid>
    </MudCardContent>
</MudCard>

<MudCard Class="mb-4">
    <MudCardHeader><MudText Typo="Typo.subtitle1">Target Position</MudText></MudCardHeader>
    <MudCardContent>
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6"><MudText Typo="Typo.caption">Target RA</MudText><MudText>@FormatHMS(_state.TargetRightAscension)</MudText></MudItem>
            <MudItem xs="12" sm="6"><MudText Typo="Typo.caption">Target Dec</MudText><MudText>@FormatDMS(_state.TargetDeclination)</MudText></MudItem>
        </MudGrid>
    </MudCardContent>
</MudCard>

<MudCard Class="mb-4">
    <MudCardHeader><MudText Typo="Typo.subtitle1">Axis Positions (Mount Coordinates)</MudText></MudCardHeader>
    <MudCardContent>
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Actual Axis X</MudText><MudText>@FormatDegrees(_state.ActualAxisX)</MudText></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Actual Axis Y</MudText><MudText>@FormatDegrees(_state.ActualAxisY)</MudText></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">App Axis X</MudText><MudText>@FormatDegrees(_state.AppAxisX)</MudText></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">App Axis Y</MudText><MudText>@FormatDegrees(_state.AppAxisY)</MudText></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Axis 1 Steps</MudText><MudText>@_state.Axis1Steps.ToString("N0")</MudText></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Axis 2 Steps</MudText><MudText>@_state.Axis2Steps.ToString("N0")</MudText></MudItem>
        </MudGrid>
    </MudCardContent>
</MudCard>

<MudCard Class="mb-4">
    <MudCardHeader><MudText Typo="Typo.subtitle1">Tracking &amp; Guiding</MudText></MudCardHeader>
    <MudCardContent>
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Pulse Guide RA</MudText><MudText Color="@StatusColor(_state.IsPulseGuidingRa)">@_state.IsPulseGuidingRa</MudText></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Pulse Guide Dec</MudText><MudText Color="@StatusColor(_state.IsPulseGuidingDec)">@_state.IsPulseGuidingDec</MudText></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Tracking Rate</MudText><MudText>@_state.TrackingRate</MudText></MudItem>
        </MudGrid>
    </MudCardContent>
</MudCard>

<MudCard Class="mb-4">
    <MudCardHeader><MudText Typo="Typo.subtitle1">Time &amp; Performance</MudText></MudCardHeader>
    <MudCardContent>
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">UTC Date</MudText><MudText>@_state.UTCDate.ToString("yyyy-MM-dd HH:mm:ss.fff")</MudText></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Local Date</MudText><MudText>@_state.LocalDate.ToString("yyyy-MM-dd HH:mm:ss.fff")</MudText></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Loop Counter</MudText><MudText>@_state.LoopCounter.ToString("N0")</MudText></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Timer Overruns</MudText><MudText Color="@OverrunColor(_state.TimerOverruns)">@_state.TimerOverruns</MudText></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Last Update</MudText><MudText>@_state.LastUpdate.ToString("HH:mm:ss.fff")</MudText></MudItem>
        </MudGrid>
    </MudCardContent>
</MudCard>

@code {
    [Parameter] public int DeviceNumber { get; set; }

    private TelescopeStateModel _state = new();

    protected override void OnInitialized()
    {
        StateService.StateChanged += OnStateChanged;
        _state = StateService.GetCurrentState(DeviceNumber);
    }

    protected override void OnParametersSet()
    {
        _state = StateService.GetCurrentState(DeviceNumber);
    }

    private void OnStateChanged(object? sender, EventArgs e)
    {
        _state = StateService.GetCurrentState(DeviceNumber);
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        StateService.StateChanged -= OnStateChanged;
    }
    
    private string FormatHMS(double hours)
    {
        if (double.IsNaN(hours) || double.IsInfinity(hours))
            return "N/A";

        var sign = hours < 0 ? "-" : "+";
        hours = Math.Abs(hours);

        
        var h = (int)hours;
        var m = (int)((hours - h) * 60);
        var s = ((hours - h) * 60 - m) * 60;
        
        return $"{sign}{h:00}h {m:00}m {s:00.00}s";
    }
    
    private string FormatDMS(double degrees)
    {
        if (double.IsNaN(degrees) || double.IsInfinity(degrees))
            return "N/A";
        
        var sign = degrees < 0 ? "-" : "+";
        degrees = Math.Abs(degrees);
        
        var d = (int)degrees;
        var m = (int)((degrees - d) * 60);
        var s = ((degrees - d) * 60 - m) * 60;
        
        return $"{sign}{d:00}° {m:00}' {s:00.0}\"";
    }
    
    private string FormatDegrees(double degrees)
    {
        if (double.IsNaN(degrees) || double.IsInfinity(degrees))
            return "N/A";
        
        return $"{degrees:F4}°";
    }
    
    private Color StatusColor(bool active) => active ? Color.Success : Color.Default;
    private Color OverrunColor(int value) => value > 0 ? Color.Warning : Color.Default;
}
