@page "/telescope-state"
@page "/telescope-state/{DeviceNumber:int}"
@using GreenSwamp.Alpaca.Server.Services
@using GreenSwamp.Alpaca.Server.Models
@using GreenSwamp.Alpaca.MountControl
@using ASCOM.Common.DeviceInterfaces
@inject TelescopeStateService StateService
@implements IDisposable

<PageTitle>Telescope State</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true">Telescope Device State</MudText>

<MudTabs Rounded="true" Elevation="1" @bind-ActivePanelIndex="ActiveTabIndex" Class="mb-4">
    @foreach (var dn in MountRegistry.GetAllInstances().Select(kvp => kvp.Key).OrderBy(k => k))
    {
        <MudTabPanel Text="@($"Device {dn}")">
            @{
                var s = StateService.GetCurrentState(dn);
            }

            <MudCard Class="mb-4">
                <MudCardHeader><MudText Typo="Typo.subtitle1">Connection &amp; Status</MudText></MudCardHeader>
                <MudCardContent>
                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Mount Running</MudText><MudText Color="@StatusColor(s.IsMountRunning)">@s.IsMountRunning</MudText></MudItem>
                        <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Slewing</MudText><MudText Color="@StatusColor(s.Slewing)">@s.Slewing</MudText></MudItem>
                        <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Tracking</MudText><MudText Color="@StatusColor(s.Tracking)">@s.Tracking</MudText></MudItem>
                        <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">At Park</MudText><MudText>@s.AtPark</MudText></MudItem>
                        <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">At Home</MudText><MudText>@s.AtHome</MudText></MudItem>
                        <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Slew State</MudText><MudText>@s.SlewState</MudText></MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>

            <MudCard Class="mb-4">
                <MudCardHeader><MudText Typo="Typo.subtitle1">Current Position (ASCOM)</MudText></MudCardHeader>
                <MudCardContent>
                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Right Ascension</MudText><MudText>@FormatHMS(s.RightAscension)</MudText></MudItem>
                        <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Declination</MudText><MudText>@FormatDMS(s.Declination)</MudText></MudItem>
                        <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Altitude</MudText><MudText>@FormatDegrees(s.Altitude)</MudText></MudItem>
                        <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Azimuth</MudText><MudText>@FormatDegrees(s.Azimuth)</MudText></MudItem>
                        <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Side of Pier</MudText><MudText>@s.SideOfPier</MudText></MudItem>
                        <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Local Hour Angle</MudText><MudText>@FormatHMS(s.LocalHourAngle)</MudText></MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>

            <MudCard Class="mb-4">
                <MudCardHeader><MudText Typo="Typo.subtitle1">Target Position</MudText></MudCardHeader>
                <MudCardContent>
                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="6"><MudText Typo="Typo.caption">Target RA</MudText><MudText>@FormatHMS(s.TargetRightAscension)</MudText></MudItem>
                        <MudItem xs="12" sm="6"><MudText Typo="Typo.caption">Target Dec</MudText><MudText>@FormatDMS(s.TargetDeclination)</MudText></MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>

            <MudCard Class="mb-4">
                <MudCardHeader><MudText Typo="Typo.subtitle1">Axis Positions (Mount Coordinates)</MudText></MudCardHeader>
                <MudCardContent>
                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Actual Axis X</MudText><MudText>@FormatDegrees(s.ActualAxisX)</MudText></MudItem>
                        <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Actual Axis Y</MudText><MudText>@FormatDegrees(s.ActualAxisY)</MudText></MudItem>
                        <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">App Axis X</MudText><MudText>@FormatDegrees(s.AppAxisX)</MudText></MudItem>
                        <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">App Axis Y</MudText><MudText>@FormatDegrees(s.AppAxisY)</MudText></MudItem>
                        <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Axis 1 Steps</MudText><MudText>@s.Axis1Steps.ToString("N0")</MudText></MudItem>
                        <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Axis 2 Steps</MudText><MudText>@s.Axis2Steps.ToString("N0")</MudText></MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>

            <MudCard Class="mb-4">
                <MudCardHeader><MudText Typo="Typo.subtitle1">Tracking &amp; Guiding</MudText></MudCardHeader>
                <MudCardContent>
                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Pulse Guide RA</MudText><MudText Color="@StatusColor(s.IsPulseGuidingRa)">@s.IsPulseGuidingRa</MudText></MudItem>
                        <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Pulse Guide Dec</MudText><MudText Color="@StatusColor(s.IsPulseGuidingDec)">@s.IsPulseGuidingDec</MudText></MudItem>
                        <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Tracking Rate</MudText><MudText>@s.TrackingRate</MudText></MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>

            <MudCard Class="mb-4">
                <MudCardHeader><MudText Typo="Typo.subtitle1">Time &amp; Performance</MudText></MudCardHeader>
                <MudCardContent>
                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">UTC Date</MudText><MudText>@s.UTCDate.ToString("yyyy-MM-dd HH:mm:ss.fff")</MudText></MudItem>
                        <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Local Date</MudText><MudText>@s.LocalDate.ToString("yyyy-MM-dd HH:mm:ss.fff")</MudText></MudItem>
                        <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Loop Counter</MudText><MudText>@s.LoopCounter.ToString("N0")</MudText></MudItem>
                        <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Timer Overruns</MudText><MudText Color="@OverrunColor(s.TimerOverruns)">@s.TimerOverruns</MudText></MudItem>
                        <MudItem xs="12" sm="6" md="4"><MudText Typo="Typo.caption">Last Update</MudText><MudText>@s.LastUpdate.ToString("HH:mm:ss.fff")</MudText></MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>

            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ArrowBack" Href="/device-manager">Back to Device Manager</MudButton>
        </MudTabPanel>
    }
</MudTabs>

@code {
    [Parameter] public int DeviceNumber { get; set; }

    private TelescopeStateModel _state = new();
    private int ActiveTabIndex { get; set; }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        // Keep the active tab in sync with route parameter
        var keys = MountRegistry.GetAllInstances().Select(kvp => kvp.Key).OrderBy(k => k).ToList();
        var idx = keys.IndexOf(DeviceNumber);
        ActiveTabIndex = idx >= 0 ? idx : 0;

        _state = StateService.GetCurrentState(DeviceNumber);
    }

    protected override void OnInitialized()
    {
        StateService.StateChanged += OnStateChanged;
        _state = StateService.GetCurrentState(DeviceNumber);
    }


    private void OnStateChanged(object? sender, EventArgs e)
    {
        _state = StateService.GetCurrentState(DeviceNumber);
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        StateService.StateChanged -= OnStateChanged;
    }
    
    private string FormatHMS(double hours)
    {
        if (double.IsNaN(hours) || double.IsInfinity(hours))
            return "N/A";

        var sign = hours < 0 ? "-" : "+";
        hours = Math.Abs(hours);

        
        var h = (int)hours;
        var m = (int)((hours - h) * 60);
        var s = ((hours - h) * 60 - m) * 60;
        
        return $"{sign}{h:00}h {m:00}m {s:00.00}s";
    }
    
    private string FormatDMS(double degrees)
    {
        if (double.IsNaN(degrees) || double.IsInfinity(degrees))
            return "N/A";
        
        var sign = degrees < 0 ? "-" : "+";
        degrees = Math.Abs(degrees);
        
        var d = (int)degrees;
        var m = (int)((degrees - d) * 60);
        var s = ((degrees - d) * 60 - m) * 60;
        
        return $"{sign}{d:00}° {m:00}' {s:00.0}\"";
    }
    
    private string FormatDegrees(double degrees)
    {
        if (double.IsNaN(degrees) || double.IsInfinity(degrees))
            return "N/A";
        
        return $"{degrees:F4}°";
    }
    
    private Color StatusColor(bool active) => active ? Color.Success : Color.Default;
    private Color OverrunColor(int value) => value > 0 ? Color.Warning : Color.Default;
}
