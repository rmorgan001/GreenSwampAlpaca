@page "/"
@using GreenSwamp.Alpaca.Settings.Models

<PageTitle>Home – Green Swamp Alpaca Server</PageTitle>

<div class="gs-home-hero-wrap">
<div class="gs-home-hero">
    <div class="gs-home-overlay"></div>

    <div class="gs-home-content">
        <h1 class="gs-home-title">
            Welcome to <span>Green Swamp Alpaca</span> Server <small>(v@(ServerConfig.GetVersion()))</small>
        </h1>

        <ul class="gs-home-bullets">
            <li>ASCOM Alpaca-compliant mount driver server for SkyWatcher and compatible mounts</li>
            <li>Supports German Equatorial (GEM), Polar / Fork Equatorial and Alt-Az mounts</li>
            <li>Provides simulator for all mount types for testing and development</li>
            <li>Parallel control of multiple mounts by multiple ASCOM clients</li>
            <li>Blazor-based web UI for real-time mount status, tracking, and configuration</li>
            <li>Supports custom tracking rates, pulse guiding, and park/unpark sequences</li>
            <li>Runs as a local network service — connect any Alpaca-aware planetarium or imaging app</li>
        </ul>

