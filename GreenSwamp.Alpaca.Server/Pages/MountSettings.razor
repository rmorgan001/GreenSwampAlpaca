@page "/mount-settings"
@page "/mount-settings/{DeviceNumber:int}"
@using System.Linq
@using GreenSwamp.Alpaca.MountControl
@using GreenSwamp.Alpaca.Server.Pages.Devices
@using GreenSwamp.Alpaca.Settings.Models
@using GreenSwamp.Alpaca.Settings.Services
@inject IVersionedSettingsService SettingsService

<PageTitle>Mount Settings</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true">Mount Settings</MudText>

@if (_alpacaDevices.Count == 0)
{
    <MudAlert Severity="Severity.Info">No mount devices registered.</MudAlert>
}
else
{
    <MudTabs Rounded="true" Elevation="1" Class="gs-tabs-no-transform"
             ActivePanelIndex="@_activeDeviceTabIndex"
             ActivePanelIndexChanged="OnDeviceTabChanged">
    @foreach (var device in GetConfiguredDeviceNumbers())
        {
            <MudTabPanel Text="@TabLabel(device)">
                @* Inline: reuse TelescopeSetup component/page UI for read-only view *@
                <MudGrid>
                    <MudItem xs="12">
                        <MudCard Class="mb-2">
                            <MudCardContent>
                                <TelescopeSetup InstanceID="@device" />
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="() => EditDevice(device)"
                                           StartIcon="@Icons.Material.Filled.AccountTree">
                                    Edit in Settings Explorer
                                </MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
        }
    </MudTabs>
}

@code {
    [Parameter] public int DeviceNumber { get; set; }

    private int _activeDeviceTabIndex;
    private List<AlpacaDevice> _alpacaDevices = [];

    protected override void OnInitialized()
    {
        _alpacaDevices = SettingsService.GetAlpacaDevices();
    }

    protected override void OnParametersSet()
    {
        _alpacaDevices = SettingsService.GetAlpacaDevices();
        var keys = GetConfiguredDeviceNumbers();
        var idx = keys.IndexOf(DeviceNumber);
        _activeDeviceTabIndex = idx >= 0 ? idx : 0;
    }

    private void OnDeviceTabChanged(int index)
    {
        var keys = GetConfiguredDeviceNumbers();
        if (index >= 0 && index < keys.Count)
            NavManager.NavigateTo($"/mount-settings/{keys[index]}");
    }

    private List<int> GetConfiguredDeviceNumbers() =>
        _alpacaDevices
            .Select(d => d.DeviceNumber)
            .OrderBy(d => d)
            .ToList();

    private string TabLabel(int deviceNumber)
    {
        var device = _alpacaDevices.FirstOrDefault(d => d.DeviceNumber == deviceNumber);
        return string.IsNullOrWhiteSpace(device?.DeviceName)
            ? $"Device {deviceNumber}"
            : device.DeviceName;
    }

    void EditDevice(int deviceNumber)
    {
        NavManager.NavigateTo($"/settings-explorer?device={deviceNumber}&group=Mount%20Configuration");
    }

    [Inject]
    NavigationManager NavManager { get; set; } = default!;
}
