@using GreenSwamp.Alpaca.Settings.Services
@using MudBlazor
@namespace GreenSwamp.Alpaca.Server.Components

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.h6">Download Settings & Logs Export</MudText>

            @if (_state == ExportState.Initial)
            {
                <MudText Typo="Typo.body2" Color="Color.Default">
                    Preparing export of all settings and user logs...
                </MudText>

                @if (_exportInfo != null)
                {
                    <MudStack Spacing="1" Class="mud-paper pa-3" Style="background-color: rgba(63, 81, 181, 0.1);">
                        <MudText Typo="Typo.caption">
                            <strong>Files:</strong> @_exportInfo.FileCount
                        </MudText>
                        <MudText Typo="Typo.caption">
                            <strong>Estimated size:</strong> @_exportInfo.EstimatedSizeFormatted
                        </MudText>
                    </MudStack>
                }
            }
            else if (_state == ExportState.InProgress)
            {
                <MudText Typo="Typo.body2" Color="Color.Default">
                    Creating export file...
                </MudText>

                <MudProgressLinear
                    Value="@_progress"
                    Max="100"
                    Color="Color.Primary"
                    Striped="true"
                    Size="Size.Medium"
                    Class="my-2" />

                <MudText Typo="Typo.caption" Align="Align.Center">
                    @_progress%
                </MudText>
            }
            else if (_state == ExportState.Success)
            {
                <MudAlert Severity="Severity.Success" Class="my-2">
                    Backup created successfully! Download started.
                </MudAlert>

                <MudText Typo="Typo.body2" Color="Color.Default">
                    Your export file contains all JSON settings files and logs.
                </MudText>
            }
            else if (_state == ExportState.Error)
            {
                <MudAlert Severity="Severity.Error" Class="my-2">
                    @_errorMessage
                </MudAlert>
            }
        </MudStack>
    </DialogContent>

    <DialogActions>
        @if (_state == ExportState.Initial)
        {
            <MudButton OnClick="Cancel">Cancel</MudButton>
            <MudButton Color="Color.Primary" OnClick="CreateExport" Variant="Variant.Filled">
                Create Export
            </MudButton>
        }
        else if (_state == ExportState.InProgress)
        {
            <MudButton OnClick="Cancel" Disabled="true">Cancel</MudButton>
        }
        else if (_state == ExportState.Success)
        {
            <MudButton Color="Color.Primary" OnClick="Cancel" Variant="Variant.Filled">
                Close
            </MudButton>
        }
        else if (_state == ExportState.Error)
        {
            <MudButton OnClick="Cancel">Close</MudButton>
            <MudButton Color="Color.Primary" OnClick="Retry" Variant="Variant.Filled">
                Retry
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Inject]
    private ISettingsExportService ExportService { get; set; } = null!;

    [Inject]
    private IJSRuntime JSRuntime { get; set; } = null!;

    private enum ExportState
    {
        Initial,
        InProgress,
        Success,
        Error
    }

    private ExportState _state = ExportState.Initial;
    private int _progress = 0;
    private string _errorMessage = string.Empty;
    private ExportInfo? _exportInfo;

    protected override async Task OnInitializedAsync()
    {
        await LoadExportInfo();
    }

    private async Task LoadExportInfo()
    {
        try
        {
            _exportInfo = await ExportService.GetExportInfoAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load backup information: {ex.Message}";
            _state = ExportState.Error;
        }
    }

    private async Task CreateExport()
    {
        _state = ExportState.InProgress;
        _progress = 0;

        try
        {
            using var blob = await ExportService.GenerateExportZipAsync(
                progress =>
                {
                    _progress = progress;
                    _ = InvokeAsync(StateHasChanged);
                });

            _progress = 100;
            _state = ExportState.Success;

            // Trigger browser download using JavaScript
            await using var module = await JSRuntime.InvokeAsync<IJSObjectReference>(
                "import", "./js/fileDownload.js");
            var fileName = $"GreenSwamp_{DateTime.Now:yyyy-MM-dd_HH-mm-ss}.zip";
            var bytes = blob.ToArray();
            await module.InvokeVoidAsync("downloadFile", fileName, bytes);

            // Auto-close dialog after a brief delay
            await Task.Delay(1500);
            MudDialog.Close();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error creating export: {ex.Message}";
            _state = ExportState.Error;
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task Retry()
    {
        await LoadExportInfo();
        _state = ExportState.Initial;
    }
}
