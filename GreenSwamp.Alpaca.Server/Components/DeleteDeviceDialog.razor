@using MudBlazor

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.DeleteForever" Color="Color.Error" />
            <MudText Typo="Typo.h6" Color="Color.Error">Delete Device</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3" Class="mt-2">
            <MudAlert Severity="Severity.Error" Icon="@Icons.Material.Filled.Warning">
                <MudText Typo="Typo.body1">
                    <strong>This action cannot be undone.</strong>
                </MudText>
                <MudText Typo="Typo.body2" Class="mt-1">
                    Device <strong>@DeviceNumber — @DeviceName</strong> and all its settings
                    files will be permanently removed.
                </MudText>
            </MudAlert>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Any Alpaca client currently connected to this device will lose its connection.
                The server may need to be restarted for the removal to take full effect.
            </MudText>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Filled" Color="Color.Default">
            Cancel
        </MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.DeleteForever"
                   OnClick="Confirm">
            Delete Device
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public int DeviceNumber { get; set; }
    [Parameter] public string DeviceName { get; set; } = string.Empty;

    private void Confirm() => MudDialog.Close(DialogResult.Ok(true));
    private void Cancel()  => MudDialog.Cancel();
}
