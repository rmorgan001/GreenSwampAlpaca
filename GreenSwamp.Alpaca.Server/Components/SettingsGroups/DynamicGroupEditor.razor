@using GreenSwamp.Alpaca.Server.Models
@using GreenSwamp.Alpaca.Settings.Models
@using GreenSwamp.Alpaca.Server.Components.SettingsGroups

@* Dispatches to the correct leaf-group editor component based on Node.GroupKey. *@

@if (Node is null)
{
    return;
}

@switch (Node.GroupKey)
{
    // ── Server Configuration ───────────────────────────────────────────────
    case "Network":
        <NetworkEditor Config="ServerConfig" OnChanged="OnSettingChanged" />
        break;
    case "Alpaca Behaviour":
        <AlpacaBehaviourEditor Config="ServerConfig" ShowHidden="ShowHidden" OnChanged="OnSettingChanged" />
        break;
    case "Identity & UI":
        <IdentityUiEditor Config="ServerConfig" OnChanged="OnSettingChanged" />
        break;
    case "Authentication":
        <AuthenticationEditor Config="ServerConfig" OnChanged="OnSettingChanged" />
        break;

    // ── Observatory ────────────────────────────────────────────────────────
    case "Observatory Settings":
        <ObservatoryEditor Settings="Observatory" ShowHidden="ShowHidden" DeviceSettings="DeviceSettings" OnChanged="OnSettingChanged" />
        break;

    // ── Logging ──────────────────────────────────────────────────
    case "Device Filters":
        <DeviceFiltersEditor Settings="Monitor" OnChanged="OnSettingChanged" />
        break;
    case "Category Filters":
        <CategoryFiltersEditor Settings="Monitor" OnChanged="OnSettingChanged" />
        break;
    case "Message Type Filters":
        <MessageTypeFiltersEditor Settings="Monitor" OnChanged="OnSettingChanged" />
        break;
    case "Logging Control":
        <LoggingControlEditor Settings="Monitor" ShowHidden="ShowHidden" OnChanged="OnSettingChanged" />
        break;

    // ── Telescope Device groups ────────────────────────────────────────────
    default:
        @if (Node.Source == SettingsNodeSource.Device
             && DeviceSettings is not null
             && DeviceSettings.TryGetValue(Node.DeviceNumber, out var device))
        {
            @switch (Node.GroupKey)
            {
                case "Mount Configuration":
                    <MountConfigurationEditor Device="device" ShowHidden="ShowHidden" OnChanged="OnSettingChanged" />
                    break;
                case "Observatory Configuration":
                    <ObservatoryConfigurationEditor Device="device" ShowHidden="ShowHidden" Observatory="Observatory" OnChanged="OnSettingChanged" />
                    break;
                case "Optics":
                    <OpticsEditor Device="device" ShowHidden="ShowHidden" OnChanged="OnSettingChanged" />
                    break;
                case "Tracking & Guiding":
                    <TrackingAndGuidingEditor Device="device" ShowHidden="ShowHidden" OnChanged="OnSettingChanged" />
                    break;
                case "PEC / PPEC":
                    <PecPpecEditor Device="device" ShowHidden="ShowHidden" OnChanged="OnSettingChanged" />
                    break;
                case "Hand Controller":
                    <HandControllerEditor Device="device" ShowHidden="ShowHidden" OnChanged="OnSettingChanged" />
                    break;
                case "Performance & Tuning":
                    <PerformanceTuningEditor Device="device" ShowHidden="ShowHidden" OnChanged="OnSettingChanged" />
                    break;
                case "Home and Park":
                    <HomeAndParkEditor Device="device" OnChanged="OnSettingChanged" />
                    break;
                case "Limits":
                    <LimitsEditor Device="device" OnChanged="OnSettingChanged" />
                    break;
                default:
                    <MudAlert Severity="Severity.Warning">No editor defined for group "@Node.GroupKey".</MudAlert>
                    break;
            }
        }
        else
        {
            <MudAlert Severity="Severity.Warning">No editor defined for group "@Node.GroupKey".</MudAlert>
        }
        break;
}

@code {
    [Parameter] public SettingsNode? Node { get; set; }
    [Parameter] public ObservatorySettings? Observatory { get; set; }
    [Parameter] public ServerConfig? ServerConfig { get; set; }
    [Parameter] public MonitorSettings? Monitor { get; set; }
    [Parameter] public Dictionary<int, SkySettings>? DeviceSettings { get; set; }
    [Parameter] public bool ShowHidden { get; set; }
    [Parameter] public EventCallback OnSettingChanged { get; set; }

    private async Task OnChanged() => await OnSettingChanged.InvokeAsync();
}
