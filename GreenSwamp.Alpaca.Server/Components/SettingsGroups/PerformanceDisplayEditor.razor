@using GreenSwamp.Alpaca.Settings.Models

<MudStack Spacing="3">
    <MudTooltip Text="UI display refresh interval in milliseconds." Placement="Placement.Right" Arrow="true">
        <MudNumericField T="int" @bind-Value="Device!.DisplayInterval" @bind-Value:after="NotifyChanged"
                         Label="Display Interval (ms)" Min="100" Immediate="true" />
    </MudTooltip>
    <MudTooltip Text="Maximum slew rate in degrees per second." Placement="Placement.Right" Arrow="true">
        <MudNumericField T="double" @bind-Value="Device!.MaximumSlewRate" @bind-Value:after="NotifyChanged"
                         Label="Max Slew Rate (°/s)" Format="F2" Min="0" Immediate="true" />
    </MudTooltip>
    <MudTooltip Text="GoTo precision in arcseconds." Placement="Placement.Right" Arrow="true">
        @if (ShowHidden)
        {
            <MudNumericField T="double" @bind-Value="Device!.GotoPrecision" @bind-Value:after="NotifyChanged"
                             Label="GoTo Precision (arcsec)" Format="F5" Min="0" Immediate="true" />
        }
    </MudTooltip>
    <MudTooltip Text="Enable trace/debug logging to a file for this device." Placement="Placement.Right" Arrow="true">
        <MudCheckBox @bind-Value="Device!.TraceLogger" @bind-Value:after="NotifyChanged"
                     Label="Trace Logger" Color="Color.Primary" />
    </MudTooltip>
    <MudTooltip Text="Enable full current mode on the motor drivers." Placement="Placement.Right" Arrow="true">
        <MudCheckBox @bind-Value="Device!.FullCurrent" @bind-Value:after="NotifyChanged"
                     Label="Full Current" Color="Color.Primary" />
    </MudTooltip>
    <MudTooltip Text="Polar scope LED brightness level (0–255)." Placement="Placement.Right" Arrow="true">
        <MudNumericField T="int" @bind-Value="Device!.PolarLedLevel" @bind-Value:after="NotifyChanged"
                         Label="Polar LED Level" Min="0" Max="255" Immediate="true" />
    </MudTooltip>
</MudStack>

@code {
    [Parameter] public SkySettings? Device { get; set; }
    [Parameter] public bool ShowHidden { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    private async Task NotifyChanged() => await OnChanged.InvokeAsync();
}
