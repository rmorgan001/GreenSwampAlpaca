@using GreenSwamp.Alpaca.Settings.Models
@using GreenSwamp.Alpaca.Shared
@inject MudBlazor.ISnackbar Snackbar

@* Combined editor: Location + Environmental + GPS *@

<MudExpansionPanels MultiExpansion="true" Elevation="0">

    <MudExpansionPanel Text="Location" Icon="@Icons.Material.Filled.MyLocation" Expanded="false">
        <MudStack Spacing="3">
            @if (Observatory?.Observatories is { Count: > 0 })
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudSelect T="string" @bind-Value="_selectedObservatoryId"
                               Label="Copy from observatory" Dense="true"
                               Style="max-width:240px"
                               AnchorOrigin="Origin.BottomLeft">
                        @foreach (var obs in Observatory.Observatories)
                        {
                            <MudSelectItem Value="@obs.Id">@obs.Name</MudSelectItem>
                        }
                    </MudSelect>
                    <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Copy Latitude, Longitude, Elevation and GPS settings from the selected observatory to this device." Placement="Placement.Right" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.CopyAll"
                                       Color="Color.Secondary" Size="Size.Small"
                                       Disabled="@string.IsNullOrEmpty(_selectedObservatoryId)"
                                       OnClick="CopyFromSelectedObservatory" />
                    </MudTooltip>
                </MudStack>
            }
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Geographic latitude of the device site in decimal degrees (-90 to +90)." Placement="Placement.Right" Arrow="true">
                <MudNumericField T="double" @bind-Value="Device!.Latitude" @bind-Value:after="NotifyChanged"
                                 Label="Latitude (°)" Format="F6" Min="-90" Max="90" Immediate="true" />
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Geographic longitude of the device site in decimal degrees (-180 to +180)." Placement="Placement.Right" Arrow="true">
                <MudNumericField T="double" @bind-Value="Device!.Longitude" @bind-Value:after="NotifyChanged"
                                 Label="Longitude (°)" Format="F6" Min="-180" Max="180" Immediate="true" />
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Elevation above sea level in metres." Placement="Placement.Right" Arrow="true">
                <MudNumericField T="double" @bind-Value="Device!.Elevation" @bind-Value:after="NotifyChanged"
                                 Label="Elevation (m)" Format="F1" Min="-500" Max="9000" Immediate="true" />
            </MudTooltip>
            @if (ShowHidden)
            {
                <MudTooltip Inline="false" RootStyle="max-width:260px" Text="UTC offset for this device site (hours)." Placement="Placement.Right" Arrow="true">
                    <MudNumericField T="double" @bind-Value="_utcHours" @bind-Value:after="OnUtcChanged"
                                     Label="UTC Offset (h)" Format="F2" Min="-14" Max="14" Immediate="true" />
                </MudTooltip>
            }
        </MudStack>
    </MudExpansionPanel>

    <MudExpansionPanel Text="Environmental" Icon="@Icons.Material.Filled.Air">
        <MudStack Spacing="3">
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Apply atmospheric refraction correction to pointing calculations." Placement="Placement.Right" Arrow="true">
                <MudCheckBox @bind-Value="Device!.Refraction" @bind-Value:after="NotifyChanged"
                             Label="Enable Refraction" Color="Color.Primary" />
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Ambient temperature in degrees Celsius, used for refraction correction." Placement="Placement.Right" Arrow="true">
                <MudNumericField T="double" @bind-Value="Device!.Temperature" @bind-Value:after="NotifyChanged"
                                 Label="Temperature (°C)" Format="F1" Min="-50" Max="60" Immediate="true" />
            </MudTooltip>
        </MudStack>
    </MudExpansionPanel>

    <MudExpansionPanel Text="GPS" Icon="@Icons.Material.Filled.GpsFixed">
        <MudStack Spacing="3">
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Select or type a serial port name for the GPS receiver (e.g. COM4 or /dev/ttyUSB0)." Placement="Placement.Right" Arrow="true">
                @if (_availableGpsPorts.Length > 0)
                {
                    <MudSelect @bind-Value="Device!.GpsPort" @bind-Value:after="NotifyChanged"
                                Label="GPS Port" AnchorOrigin="Origin.BottomLeft">
                        @foreach (var port in _availableGpsPorts)
                        {
                            <MudSelectItem Value="@port">@port</MudSelectItem>
                        }
                        @if (!string.IsNullOrWhiteSpace(Device!.GpsPort) && !_availableGpsPorts.Contains(Device!.GpsPort, StringComparer.OrdinalIgnoreCase))
                        {
                            <MudSelectItem Value="@Device!.GpsPort">@Device!.GpsPort (manual)</MudSelectItem>
                        }
                    </MudSelect>
                }
                else
                {
                    <MudTextField @bind-Value="Device!.GpsPort" @bind-Value:after="NotifyChanged"
                                    Label="GPS Port" Immediate="true"
                                    HelperText="No ports detected — type the port name manually." />
                }
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="GPS receiver baud rate." Placement="Placement.Right" Arrow="true">
                <MudSelect T="int" @bind-Value="Device!.GpsBaudRate" @bind-Value:after="NotifyChanged"
                            Label="GPS Baud Rate">
                    <MudSelectItem Value="4800">4800</MudSelectItem>
                    <MudSelectItem Value="9600">9600</MudSelectItem>
                    <MudSelectItem Value="19200">19200</MudSelectItem>
                    <MudSelectItem Value="38400">38400</MudSelectItem>
                    <MudSelectItem Value="57600">57600</MudSelectItem>
                    <MudSelectItem Value="115200">115200</MudSelectItem>
                </MudSelect>
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="GPS receiver serial port parity." Placement="Placement.Right" Arrow="true">
                <MudSelect T="string" @bind-Value="Device!.GpsParity" @bind-Value:after="NotifyChanged"
                            Label="GPS Parity">
                    <MudSelectItem Value="@("None")">None</MudSelectItem>
                    <MudSelectItem Value="@("Odd")">Odd</MudSelectItem>
                    <MudSelectItem Value="@("Even")">Even</MudSelectItem>
                    <MudSelectItem Value="@("Mark")">Mark</MudSelectItem>
                    <MudSelectItem Value="@("Space")">Space</MudSelectItem>
                </MudSelect>
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="GPS receiver serial port stop bits." Placement="Placement.Right" Arrow="true">
                <MudSelect T="string" @bind-Value="Device!.GpsStopBits" @bind-Value:after="NotifyChanged"
                            Label="GPS Stop Bits">
                    <MudSelectItem Value="@("None")">None</MudSelectItem>
                    <MudSelectItem Value="@("One")">One</MudSelectItem>
                    <MudSelectItem Value="@("OnePointFive")">OnePointFive</MudSelectItem>
                    <MudSelectItem Value="@("Two")">Two</MudSelectItem>
                </MudSelect>
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="GPS receiver serial port data bits." Placement="Placement.Right" Arrow="true">
                <MudSelect T="int" @bind-Value="Device!.GpsDataBits" @bind-Value:after="NotifyChanged"
                            Label="GPS Data Bits">
                    <MudSelectItem Value="5">5</MudSelectItem>
                    <MudSelectItem Value="6">6</MudSelectItem>
                    <MudSelectItem Value="7">7</MudSelectItem>
                    <MudSelectItem Value="8">8</MudSelectItem>
                </MudSelect>
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="GPS receiver serial port read timeout in milliseconds." Placement="Placement.Right" Arrow="true">
                <MudNumericField T="int" @bind-Value="Device!.GpsTimeout" @bind-Value:after="NotifyChanged"
                                 Label="GPS Timeout (ms)" Min="100" Max="30000" />
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="GPS receiver serial port handshake." Placement="Placement.Right" Arrow="true">
                <MudSelect T="string" @bind-Value="Device!.GpsHandshake" @bind-Value:after="NotifyChanged"
                            Label="GPS Handshake">
                    <MudSelectItem Value="@("None")">None</MudSelectItem>
                    <MudSelectItem Value="@("XOnXOff")">XOnXOff</MudSelectItem>
                    <MudSelectItem Value="@("RequestToSend")">RequestToSend</MudSelectItem>
                    <MudSelectItem Value="@("RequestToSendXOnXOff")">RequestToSendXOnXOff</MudSelectItem>
                </MudSelect>
            </MudTooltip>
        </MudStack>
    </MudExpansionPanel>

</MudExpansionPanels>

@code {
    [Parameter] public SkySettings? Device { get; set; }
    [Parameter] public bool ShowHidden { get; set; }
    [Parameter] public ObservatorySettings? Observatory { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    private string _selectedObservatoryId = string.Empty;
    private string[] _availableGpsPorts = [];

    protected override void OnInitialized()
    {
        _availableGpsPorts = SerialPortDiscovery.GetPortNames();
    }

    protected override void OnParametersSet()
    {
        if (Device is not null)
            _utcHours = Device.UTCOffset.TotalHours;
        // Pre-select the first observatory if none selected yet
        if (string.IsNullOrEmpty(_selectedObservatoryId) && Observatory?.Observatories is { Count: > 0 })
            _selectedObservatoryId = Observatory.Observatories[0].Id;
    }

    private async Task CopyFromSelectedObservatory()
    {
        if (Device is null || Observatory is null) return;
        var source = Observatory.Observatories.FirstOrDefault(o => o.Id == _selectedObservatoryId);
        if (source is null) return;
        Device.Latitude    = source.Latitude;
        Device.Longitude   = source.Longitude;
        Device.Elevation   = source.Elevation;
        Device.GpsPort      = source.GpsPort;
        Device.GpsBaudRate  = source.GpsBaudRate;
        Device.GpsParity    = source.GpsParity;
        Device.GpsStopBits  = source.GpsStopBits;
        Device.GpsDataBits  = source.GpsDataBits;
        Device.GpsTimeout   = source.GpsTimeout;
        Device.GpsHandshake = source.GpsHandshake;
        Snackbar.Add($"Location and GPS settings copied from '{source.Name}'.", MudBlazor.Severity.Success);
        await NotifyChanged();
    }

    private double _utcHours;

    private async Task OnUtcChanged()
    {
        if (Device is not null)
            Device.UTCOffset = TimeSpan.FromHours(_utcHours);
        await NotifyChanged();
    }

    private async Task NotifyChanged() => await OnChanged.InvokeAsync();
}
