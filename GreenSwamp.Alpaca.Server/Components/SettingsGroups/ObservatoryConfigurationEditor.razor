@using GreenSwamp.Alpaca.Settings.Models
@inject MudBlazor.ISnackbar Snackbar

@* Combined editor: Location + Environmental + GPS *@

<MudExpansionPanels MultiExpansion="true" Elevation="0">

    <MudExpansionPanel Text="Location" Icon="@Icons.Material.Filled.MyLocation" Expanded="false">
        <MudStack Spacing="3">
            @if (Observatory?.Observatories is { Count: > 0 })
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudSelect T="string" @bind-Value="_selectedObservatoryId"
                               Label="Copy from observatory" Dense="true"
                               Style="max-width:240px"
                               AnchorOrigin="Origin.BottomLeft">
                        @foreach (var obs in Observatory.Observatories)
                        {
                            <MudSelectItem Value="@obs.Id">@obs.Name</MudSelectItem>
                        }
                    </MudSelect>
                    <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Copy Latitude, Longitude and Elevation from the selected observatory to this device." Placement="Placement.Right" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.CopyAll"
                                       Color="Color.Secondary" Size="Size.Small"
                                       Disabled="@string.IsNullOrEmpty(_selectedObservatoryId)"
                                       OnClick="CopyFromSelectedObservatory" />
                    </MudTooltip>
                </MudStack>
            }
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Geographic latitude of the device site in decimal degrees (-90 to +90)." Placement="Placement.Right" Arrow="true">
                <MudNumericField T="double" @bind-Value="Device!.Latitude" @bind-Value:after="NotifyChanged"
                                 Label="Latitude (°)" Format="F6" Min="-90" Max="90" Immediate="true" />
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Geographic longitude of the device site in decimal degrees (-180 to +180)." Placement="Placement.Right" Arrow="true">
                <MudNumericField T="double" @bind-Value="Device!.Longitude" @bind-Value:after="NotifyChanged"
                                 Label="Longitude (°)" Format="F6" Min="-180" Max="180" Immediate="true" />
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Elevation above sea level in metres." Placement="Placement.Right" Arrow="true">
                <MudNumericField T="double" @bind-Value="Device!.Elevation" @bind-Value:after="NotifyChanged"
                                 Label="Elevation (m)" Format="F1" Min="-500" Max="9000" Immediate="true" />
            </MudTooltip>
            @if (ShowHidden)
            {
                <MudTooltip Inline="false" RootStyle="max-width:260px" Text="UTC offset for this device site (hours)." Placement="Placement.Right" Arrow="true">
                    <MudNumericField T="double" @bind-Value="_utcHours" @bind-Value:after="OnUtcChanged"
                                     Label="UTC Offset (h)" Format="F2" Min="-14" Max="14" Immediate="true" />
                </MudTooltip>
            }
        </MudStack>
    </MudExpansionPanel>

    <MudExpansionPanel Text="Environmental" Icon="@Icons.Material.Filled.Air">
        <MudStack Spacing="3">
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Apply atmospheric refraction correction to pointing calculations." Placement="Placement.Right" Arrow="true">
                <MudCheckBox @bind-Value="Device!.Refraction" @bind-Value:after="NotifyChanged"
                             Label="Enable Refraction" Color="Color.Primary" />
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Ambient temperature in degrees Celsius, used for refraction correction." Placement="Placement.Right" Arrow="true">
                <MudNumericField T="double" @bind-Value="Device!.Temperature" @bind-Value:after="NotifyChanged"
                                 Label="Temperature (°C)" Format="F1" Min="-50" Max="60" Immediate="true" />
            </MudTooltip>
        </MudStack>
    </MudExpansionPanel>

    @if (ShowHidden)
    {
        <MudExpansionPanel Text="GPS" Icon="@Icons.Material.Filled.GpsFixed">
            <MudStack Spacing="3">
                <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Serial port number for the GPS receiver." Placement="Placement.Right" Arrow="true">
                    <MudNumericField T="int" @bind-Value="Device!.GpsPort" @bind-Value:after="NotifyChanged"
                                     Label="GPS Port Number" Min="0" Immediate="true" />
                </MudTooltip>
                <MudTooltip Inline="false" RootStyle="max-width:260px" Text="GPS receiver baud rate." Placement="Placement.Right" Arrow="true">
                    <MudTextField @bind-Value="Device!.GpsBaudRate" @bind-Value:after="NotifyChanged"
                                  Label="GPS Baud Rate" Immediate="true" />
                </MudTooltip>
            </MudStack>
        </MudExpansionPanel>
    }

</MudExpansionPanels>

@code {
    [Parameter] public SkySettings? Device { get; set; }
    [Parameter] public bool ShowHidden { get; set; }
    [Parameter] public ObservatorySettings? Observatory { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    private string _selectedObservatoryId = string.Empty;

    protected override void OnParametersSet()
    {
        if (Device is not null)
            _utcHours = Device.UTCOffset.TotalHours;
        // Pre-select the first observatory if none selected yet
        if (string.IsNullOrEmpty(_selectedObservatoryId) && Observatory?.Observatories is { Count: > 0 })
            _selectedObservatoryId = Observatory.Observatories[0].Id;
    }

    private async Task CopyFromSelectedObservatory()
    {
        if (Device is null || Observatory is null) return;
        var source = Observatory.Observatories.FirstOrDefault(o => o.Id == _selectedObservatoryId);
        if (source is null) return;
        Device.Latitude  = source.Latitude;
        Device.Longitude = source.Longitude;
        Device.Elevation = source.Elevation;
        Snackbar.Add($"Lat/Long/Elevation copied from '{source.Name}'.", MudBlazor.Severity.Success);
        await NotifyChanged();
    }

    private double _utcHours;

    private async Task OnUtcChanged()
    {
        if (Device is not null)
            Device.UTCOffset = TimeSpan.FromHours(_utcHours);
        await NotifyChanged();
    }

    private async Task NotifyChanged() => await OnChanged.InvokeAsync();
}
