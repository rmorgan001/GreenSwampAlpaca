@using GreenSwamp.Alpaca.Settings.Models

@* Combined editor: Home Position + Park Positions *@

<MudExpansionPanels MultiExpansion="true" Elevation="0">

    <MudExpansionPanel Text="Home Position" Icon="@Icons.Material.Filled.Home" IsInitiallyExpanded="true">
        <MudStack Spacing="3">
            <MudText Typo="Typo.subtitle2">Home Position (axis steps)</MudText>
            <MudNumericField T="double" @bind-Value="Device!.HomeAxisX" @bind-Value:after="NotifyChanged"
                             Label="Home Axis X" Format="F2" Immediate="true" />
            <MudNumericField T="double" @bind-Value="Device!.HomeAxisY" @bind-Value:after="NotifyChanged"
                             Label="Home Axis Y" Format="F2" Immediate="true" />
            <MudText Typo="Typo.subtitle2" Class="mt-2">Auto-Home Position</MudText>
            <MudNumericField T="double" @bind-Value="Device!.AutoHomeAxisX" @bind-Value:after="NotifyChanged"
                             Label="Auto-Home Axis X" Format="F2" Immediate="true" />
            <MudNumericField T="double" @bind-Value="Device!.AutoHomeAxisY" @bind-Value:after="NotifyChanged"
                             Label="Auto-Home Axis Y" Format="F2" Immediate="true" />
        </MudStack>
    </MudExpansionPanel>

    <MudExpansionPanel Text="Park Positions" Icon="@Icons.Material.Filled.LocalParking" IsInitiallyExpanded="true">
        <MudStack Spacing="3">
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Name of the active park position." Placement="Placement.Right" Arrow="true">
                <MudTextField @bind-Value="Device!.ParkName" @bind-Value:after="NotifyChanged"
                              Label="Active Park Position" Immediate="true" />
            </MudTooltip>
            <MudCheckBox @bind-Value="Device!.LimitPark" @bind-Value:after="NotifyChanged"
                         Label="Park at Limit" Color="Color.Primary" />
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Name of the park position used when a limit is reached." Placement="Placement.Right" Arrow="true">
                <MudTextField @bind-Value="Device!.ParkLimitName" @bind-Value:after="NotifyChanged"
                              Label="Park Limit Position Name" Immediate="true"
                              Disabled="@(!Device!.LimitPark)" />
            </MudTooltip>
            @if (Device?.ParkPositions is { Count: > 0 })
            {
                <MudText Typo="Typo.subtitle2" Class="mt-2">Defined Park Positions</MudText>
                <MudSimpleTable Dense="true" Hover="true">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>RA/Az Axis</th>
                            <th>Dec/Alt Axis</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Device.ParkPositions)
                        {
                            <tr>
                                <td>@p.Name</td>
                                <td>@p.X.ToString("F2")</td>
                                <td>@p.Y.ToString("F2")</td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
        </MudStack>
    </MudExpansionPanel>

</MudExpansionPanels>

@code {
    [Parameter] public SkySettings? Device { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    private async Task NotifyChanged() => await OnChanged.InvokeAsync();
}
