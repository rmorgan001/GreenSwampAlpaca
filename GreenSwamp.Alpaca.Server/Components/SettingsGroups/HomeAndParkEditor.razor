@using GreenSwamp.Alpaca.Settings.Models

@* Combined editor: Home Position + Park Positions *@

<MudExpansionPanels MultiExpansion="true" Elevation="0">

    <MudExpansionPanel Text="Home" Icon="@Icons.Material.Filled.Home" Expanded="false">
        <MudStack Spacing="3">
            <MudText Typo="Typo.subtitle2">Home Positions</MudText>
            <MudSimpleTable Dense="true" Hover="true">
                <thead>
                    <tr>
                        <th>Position</th>
                        <th>RA/Az Axis</th>
                        <th>Dec/Alt Axis</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Home</td>
                        <td>@Device?.HomeAxisX.ToString("F2")</td>
                        <td>@Device?.HomeAxisY.ToString("F2")</td>
                    </tr>
                    <tr>
                        <td>Auto-Home</td>
                        <td>@Device?.AutoHomeAxisX.ToString("F2")</td>
                        <td>@Device?.AutoHomeAxisY.ToString("F2")</td>
                    </tr>
                </tbody>
            </MudSimpleTable>
        </MudStack>
    </MudExpansionPanel>

    <MudExpansionPanel Text="Park" Icon="@Icons.Material.Filled.LocalParking" Expanded="false">
        <MudStack Spacing="3">
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Name of the active park position." Placement="Placement.Right" Arrow="true">
                <MudTextField @bind-Value="Device!.ParkName" @bind-Value:after="NotifyChanged"
                              Label="Active Park Position" Immediate="true" />
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Start tracking automatically when the mount unparks." Placement="Placement.Right" Arrow="true">
                <MudCheckBox @bind-Value="Device!.TrackAfterUnpark" @bind-Value:after="NotifyChanged"
                             Label="Track After Unpark" />
            </MudTooltip>
            @if (Device?.ParkPositions is { Count: > 0 })
            {
                <MudText Typo="Typo.subtitle2" Class="mt-2">Defined Park Positions</MudText>
                <MudSimpleTable Dense="true" Hover="true">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>RA/Az Axis</th>
                            <th>Dec/Alt Axis</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Device.ParkPositions)
                        {
                            <tr>
                                <td>@p.Name</td>
                                <td>@p.X.ToString("F2")</td>
                                <td>@p.Y.ToString("F2")</td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
        </MudStack>
    </MudExpansionPanel>

</MudExpansionPanels>

@code {
    [Parameter] public SkySettings? Device { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    private async Task NotifyChanged() => await OnChanged.InvokeAsync();
}
