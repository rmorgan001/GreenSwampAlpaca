@using GreenSwamp.Alpaca.Settings.Models

@* Unified panel: hardware limit values + tracking-limit actions + sync limits *@

<MudExpansionPanels MultiExpansion="true" Elevation="0">

    <MudExpansionPanel Text="Hardware Limit Values (always enforced for slew safety)" Icon="@Icons.Material.Filled.Block" Expanded="false">
        <MudStack Spacing="3">
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Upper Dec/Alt hardware limit in degrees." Placement="Placement.Right" Arrow="true">
                <MudNumericField T="double" @bind-Value="Device!.AxisUpperLimitY" @bind-Value:after="NotifyChanged"
                                 Label="Upper Dec/Alt Hardware Limit (°)" Format="F2" Immediate="true" />
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Lower Dec/Alt hardware limit in degrees." Placement="Placement.Right" Arrow="true">
                <MudNumericField T="double" @bind-Value="Device!.AxisLowerLimitY" @bind-Value:after="NotifyChanged"
                                 Label="Lower Dec/Alt Hardware Limit (°)" Format="F2" Immediate="true" />
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="RA/Az hardware limit in degrees." Placement="Placement.Right" Arrow="true">
                <MudNumericField T="double" @bind-Value="Device!.AxisLimitX" @bind-Value:after="NotifyChanged"
                                 Label="RA/Az Hardware Limit (°)" Format="F2" Immediate="true" />
            </MudTooltip>
            @if (IsGem)
            {
                <MudTooltip Inline="false" RootStyle="max-width:260px" Text="GEM meridian safety limit in degrees." Placement="Placement.Right" Arrow="true">
                    <MudNumericField T="double" @bind-Value="Device!.HourAngleLimit" @bind-Value:after="NotifyChanged"
                                     Label="Hour Angle Limit (°)" Format="F2" Min="0" Max="30" Immediate="true" />
                </MudTooltip>
                <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Additional GEM meridian tracking allowance in degrees." Placement="Placement.Right" Arrow="true">
                    <MudNumericField T="double" @bind-Value="Device!.AxisTrackingLimit" @bind-Value:after="NotifyChanged"
                                     Label="Axis Tracking Limit (°)" Format="F2" Min="0" Max="15" Immediate="true" />
                </MudTooltip>
                <MudTooltip Inline="false" RootStyle="max-width:260px" Text="GEM horizon tracking trigger angle in degrees." Placement="Placement.Right" Arrow="true">
                    <MudNumericField T="double" @bind-Value="Device!.AxisHzTrackingLimit" @bind-Value:after="NotifyChanged"
                                     Label="Horizon Trigger Limit (°)" Format="F2" Immediate="true" />
                </MudTooltip>
            }
        </MudStack>
    </MudExpansionPanel>

    <MudExpansionPanel Text="Tracking-Limit Actions (controlled by Limits On)" Icon="@Icons.Material.Filled.WarningAmber" Expanded="false">
        <MudStack Spacing="3">
            <MudCheckBox @bind-Value="Device!.LimitsOn" @bind-Value:after="NotifyChanged"
                         Label="Limits On" Color="Color.Primary" />

            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="@PrimaryActionHelpText" Placement="Placement.Right" Arrow="true">
                <MudSelect T="string" Value="@PrimaryAction" ValueChanged="OnPrimaryActionChanged" Label="@PrimaryActionLabel">
                    <MudSelectItem Value="@ActionWarningOnly">Warning Only</MudSelectItem>
                    <MudSelectItem Value="@ActionStopTracking">Stop Tracking</MudSelectItem>
                    <MudSelectItem Value="@ActionPark">Park</MudSelectItem>
                </MudSelect>
            </MudTooltip>

            <MudSelect T="string"
                       Value="@Device!.ParkLimitName"
                       ValueChanged="OnPrimaryParkPositionChanged"
                       Label="Primary Action Park Position"
                       Disabled="@(PrimaryAction != ActionPark)">
                @foreach (var name in ParkPositionNames)
                {
                    <MudSelectItem Value="@name">@name</MudSelectItem>
                }
            </MudSelect>

            @if (IsGem)
            {
                <MudDivider />
                <MudText Typo="Typo.subtitle2">GEM Horizon Action</MudText>

                <MudSelect T="string" Value="@HorizonAction" ValueChanged="OnHorizonActionChanged" Label="Horizon Trigger Action">
                    <MudSelectItem Value="@ActionWarningOnly">Warning Only</MudSelectItem>
                    <MudSelectItem Value="@ActionStopTracking">Stop Tracking</MudSelectItem>
                    <MudSelectItem Value="@ActionPark">Park</MudSelectItem>
                </MudSelect>

                <MudSelect T="string"
                           Value="@Device!.ParkHzLimitName"
                           ValueChanged="OnHorizonParkPositionChanged"
                           Label="Horizon Action Park Position"
                           Disabled="@(HorizonAction != ActionPark)">
                    @foreach (var name in ParkPositionNames)
                    {
                        <MudSelectItem Value="@name">@name</MudSelectItem>
                    }
                </MudSelect>
            }
        </MudStack>
    </MudExpansionPanel>

    <MudExpansionPanel Text="Sync Limits" Icon="@Icons.Material.Filled.SyncAlt" Expanded="false">
        <MudStack Spacing="3">
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Enable sync angle limit — reject syncs that would move the model by more than this angle." Placement="Placement.Right" Arrow="true">
                <MudCheckBox @bind-Value="Device!.SyncLimitOn" @bind-Value:after="NotifyChanged"
                             Label="Enable Sync Limit" Color="Color.Primary" />
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Maximum angle in degrees by which a sync may shift the pointing model." Placement="Placement.Right" Arrow="true">
                <MudNumericField T="int" @bind-Value="Device!.SyncLimit" @bind-Value:after="NotifyChanged"
                                 Label="Sync Limit (°)" Min="0" Max="60" Immediate="true"
                                 Disabled="@(!Device!.SyncLimitOn)" />
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Reject sync requests when the scope is past the meridian (GEM/Polar)." Placement="Placement.Right" Arrow="true">
                <MudCheckBox @bind-Value="Device!.NoSyncPastMeridian" @bind-Value:after="NotifyChanged"
                             Label="No Sync Past Meridian" Color="Color.Primary" />
            </MudTooltip>
        </MudStack>
    </MudExpansionPanel>

</MudExpansionPanels>

@code {
    [Parameter] public SkySettings? Device { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    private const string ActionWarningOnly = "WarningOnly";
    private const string ActionStopTracking = "StopTracking";
    private const string ActionPark = "Park";

    private bool IsGem => Device?.AlignmentMode?.Equals("GermanPolar", StringComparison.OrdinalIgnoreCase) ?? false;

    private string PrimaryActionLabel => IsGem
        ? "Primary Trigger Action (GEM Meridian)"
        : "Primary Trigger Action (Hardware Limits)";

    private string PrimaryActionHelpText => IsGem
        ? "Action to take when GEM meridian limit is reached."
        : "Action to take when hardware limits are reached while tracking.";

    private IReadOnlyList<string> ParkPositionNames =>
        Device?.ParkPositions?.Select(p => p.Name).Where(n => !string.IsNullOrWhiteSpace(n)).Distinct().OrderBy(n => n).ToList()
        ?? [];

    private string PrimaryAction =>
        Device is null ? ActionWarningOnly
        : Device.LimitPark ? ActionPark
        : Device.LimitTracking ? ActionStopTracking
        : ActionWarningOnly;

    private string HorizonAction =>
        Device is null ? ActionWarningOnly
        : Device.HzLimitPark ? ActionPark
        : Device.HzLimitTracking ? ActionStopTracking
        : ActionWarningOnly;

    private bool _initialized;

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender) _initialized = true;
    }

    private async Task OnPrimaryActionChanged(string value)
    {
        if (Device is null) return;
        Device.LimitTracking = value == ActionStopTracking;
        Device.LimitPark = value == ActionPark;
        await NotifyChanged();
    }

    private async Task OnHorizonActionChanged(string value)
    {
        if (Device is null) return;
        Device.HzLimitTracking = value == ActionStopTracking;
        Device.HzLimitPark = value == ActionPark;
        await NotifyChanged();
    }

    private async Task OnPrimaryParkPositionChanged(string value)
    {
        if (Device is null) return;
        Device.ParkLimitName = value ?? string.Empty;
        await NotifyChanged();
    }

    private async Task OnHorizonParkPositionChanged(string value)
    {
        if (Device is null) return;
        Device.ParkHzLimitName = value ?? string.Empty;
        await NotifyChanged();
    }

    private async Task NotifyChanged()
    {
        if (!_initialized) return;
        await OnChanged.InvokeAsync();
    }
}
