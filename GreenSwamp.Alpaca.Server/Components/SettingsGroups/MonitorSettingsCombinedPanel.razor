@using GreenSwamp.Alpaca.Settings.Models
@using GreenSwamp.Alpaca.Shared

<MudCard Class="mb-4">
    <MudCardHeader>
        <CardHeaderContent>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudIcon Icon="@Icons.Material.Filled.ManageSearch" />
                <MudText Typo="Typo.h6">Logging Settings</MudText>
            </MudStack>
        </CardHeaderContent>
        <CardHeaderActions>
            @if (IsDirty)
            {
                <MudChip T="string" Color="Color.Warning" Size="Size.Small"
                         Icon="@Icons.Material.Filled.Edit">Unsaved</MudChip>
            }
        </CardHeaderActions>
    </MudCardHeader>

    <MudCardContent>
        <MudStack Spacing="3">
            @* ── Filter & Logging control grid ──────────────────────────────── *@
            <table style="table-layout:fixed; width:100%; border-collapse:collapse;">
                <colgroup>
                    <col style="width:110px;" />
                    <col />
                    <col />
                    <col />
                    <col />
                    <col />
                </colgroup>
                <tbody>
                    @* Device filter row *@
                    <tr>
                        <td style="padding:0 8px 0 4px; vertical-align:middle; white-space:nowrap;">
                            <span class="mud-text-secondary" style="font-size:0.75rem; font-weight:500;">Device</span>
                        </td>
                        <td><MudCheckBox @bind-Value="Settings!.ServerDevice" @bind-Value:after="NotifyChanged"
                                         Label="Server Device" Dense="true" Color="Color.Primary" /></td>
                        <td><MudCheckBox @bind-Value="Settings!.Telescope" @bind-Value:after="NotifyChanged"
                                         Label="Telescope" Dense="true" Color="Color.Primary" /></td>
                        <td><MudCheckBox @bind-Value="Settings!.Ui" @bind-Value:after="NotifyChanged"
                                         Label="UI" Dense="true" Color="Color.Primary" /></td>
                        <td><MudCheckBox @bind-Value="Settings!.Other" @bind-Value:after="NotifyChanged"
                                         Label="Other" Dense="true" Color="Color.Primary" /></td>
                        <td></td>
                    </tr>
                    @* Category filter row *@
                    <tr>
                        <td style="padding:0 8px 0 4px; vertical-align:middle; white-space:nowrap;">
                            <span class="mud-text-secondary" style="font-size:0.75rem; font-weight:500;">Category</span>
                        </td>
                        <td><MudCheckBox @bind-Value="Settings!.Driver" @bind-Value:after="NotifyChanged"
                                         Label="Driver" Dense="true" Color="Color.Primary" /></td>
                        <td><MudCheckBox @bind-Value="Settings!.Interface" @bind-Value:after="NotifyChanged"
                                         Label="Interface" Dense="true" Color="Color.Primary" /></td>
                        <td><MudCheckBox @bind-Value="Settings!.Server" @bind-Value:after="NotifyChanged"
                                         Label="Server" Dense="true" Color="Color.Primary" /></td>
                        <td><MudCheckBox @bind-Value="Settings!.Mount" @bind-Value:after="NotifyChanged"
                                         Label="Mount" Dense="true" Color="Color.Primary" /></td>
                        <td><MudCheckBox @bind-Value="Settings!.Alignment" @bind-Value:after="NotifyChanged"
                                         Label="Alignment" Dense="true" Color="Color.Primary" /></td>
                    </tr>
                    @* Message type filter row *@
                    <tr>
                        <td style="padding:0 8px 0 4px; vertical-align:middle; white-space:nowrap;">
                            <span class="mud-text-secondary" style="font-size:0.75rem; font-weight:500;">Type</span>
                        </td>
                        <td><MudCheckBox @bind-Value="Settings!.Information" @bind-Value:after="NotifyChanged"
                                         Label="Information" Dense="true" Color="Color.Primary" /></td>
                        <td><MudCheckBox @bind-Value="Settings!.Data" @bind-Value:after="NotifyChanged"
                                         Label="Data" Dense="true" Color="Color.Primary" /></td>
                        <td><MudCheckBox @bind-Value="Settings!.Warning" @bind-Value:after="NotifyChanged"
                                         Label="Warning" Dense="true" Color="Color.Warning" /></td>
                        <td><MudCheckBox @bind-Value="Settings!.Error" @bind-Value:after="NotifyChanged"
                                         Label="Error" Dense="true" Color="Color.Error" /></td>
                        <td><MudCheckBox @bind-Value="Settings!.Debug" @bind-Value:after="NotifyChanged"
                                         Label="Debug" Dense="true" Color="Color.Info" /></td>
                    </tr>
                    @* Logging control row *@
                    <tr>
                        <td style="padding:0 8px 0 4px; vertical-align:middle; white-space:nowrap;">
                            <span class="mud-text-secondary" style="font-size:0.75rem; font-weight:500;">Logging</span>
                        </td>
                        <td>
                            <MudTooltip Text="Must be ON for any log files to be written."
                                        Placement="Placement.Bottom" Arrow="true" Inline="false" RootStyle="max-width:240px">
                                <MudCheckBox @bind-Value="Settings!.StartMonitor" @bind-Value:after="NotifyChanged"
                                             Label="Auto-start" Dense="true" Color="Color.Primary" />
                            </MudTooltip>
                        </td>
                        <td>
                            <MudTooltip Text="Writes monitor output to GSMonitorLog*.txt. Mutually exclusive with Fast Monitor."
                                        Placement="Placement.Bottom" Arrow="true" Inline="false" RootStyle="max-width:260px">
                                <MudCheckBox Value="Settings!.LogMonitor" ValueChanged="@((bool v) => OnLogMonitorChangedAsync(v))"
                                             Label="Log Monitor" Dense="true" Color="Color.Primary" />
                            </MudTooltip>
                        </td>
                        <td><MudCheckBox @bind-Value="Settings!.LogSession" @bind-Value:after="NotifyChanged"
                                         Label="Log Session" Dense="true" Color="Color.Primary" /></td>
                        <td><MudCheckBox @bind-Value="Settings!.LogCharting" @bind-Value:after="NotifyChanged"
                                         Label="Log Charting" Dense="true" Color="Color.Primary" /></td>
                        <td>
                            @if (ShowHidden)
                            {
                                <MudTooltip Text="1000-record ring buffer — lower overhead than Log Monitor. Mutually exclusive with Log Monitor."
                                            Placement="Placement.Bottom" Arrow="true" Inline="false" RootStyle="max-width:260px">
                                    <MudCheckBox Value="Settings!.FastMonitor" ValueChanged="@((bool v) => OnFastMonitorChangedAsync(v))"
                                                 Label="Fast Monitor" Dense="true" Color="Color.Info" />
                                </MudTooltip>
                            }
                        </td>
                    </tr>
                    @if (ShowHidden)
                    {
                        @* Log path row (hidden) *@
                        <tr>
                            <td style="padding:4px 8px 2px 4px; vertical-align:middle; white-space:nowrap;">
                                <span class="mud-text-secondary" style="font-size:0.75rem; font-weight:500;">Log Path</span>
                            </td>
                            <td colspan="5" style="padding-top:4px;">
                                <MudTooltip Text="Directory path where log files are written. Leave empty for the default location (%USERPROFILE%\Documents\GreenSwamp\Server)."
                                            Placement="Placement.Bottom" Arrow="true" Inline="false" RootStyle="max-width:320px">
                                    <MudTextField @bind-Value="Settings!.LogPath" @bind-Value:after="NotifyChanged"
                                                  Label="Log Path" Immediate="true" Margin="Margin.Dense" />
                                </MudTooltip>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <MudDivider />

            @* ── Presets & Quick Actions row ─────────────────────────────────── *@
            <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center">
                <MudSelect T="string?" @bind-Value="_selectedPreset" @bind-Value:after="OnPresetChangedAsync"
                           Label="Configuration Presets"
                           AdornmentIcon="@Icons.Material.Filled.Layers" Adornment="Adornment.Start"
                           Variant="Variant.Outlined" Margin="Margin.Dense"
                           Style="min-width:240px">
                    <MudSelectItem T="string?" Value="@("Development")">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.Build" Color="Color.Success" Size="Size.Small" />
                            <span>Development</span>
                        </MudStack>
                    </MudSelectItem>
                    <MudSelectItem T="string?" Value="@("Production")">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.Check" Color="Color.Primary" Size="Size.Small" />
                            <span>Production</span>
                        </MudStack>
                    </MudSelectItem>
                    <MudSelectItem T="string?" Value="@("Troubleshooting")">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.BugReport" Color="Color.Warning" Size="Size.Small" />
                            <span>Troubleshooting</span>
                        </MudStack>
                    </MudSelectItem>
                    <MudSelectItem T="string?" Value="@("ProfileDebug")">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Info" Size="Size.Small" />
                            <span>Profile Debug</span>
                        </MudStack>
                    </MudSelectItem>
                </MudSelect>

                <MudSelect T="string?" @bind-Value="_selectedQuickAction" @bind-Value:after="OnQuickActionChangedAsync"
                           Label="Quick Actions"
                           AdornmentIcon="@Icons.Material.Filled.Bolt" Adornment="Adornment.Start"
                           Variant="Variant.Outlined" Margin="Margin.Dense"
                           Style="min-width:220px">
                    <MudSelectItem T="string?" Value="@("SelectAllDevices")">All Devices</MudSelectItem>
                    <MudSelectItem T="string?" Value="@("SelectAllCategories")">All Categories</MudSelectItem>
                    <MudSelectItem T="string?" Value="@("SelectAllTypes")">All Types</MudSelectItem>
                    <MudSelectItem T="string?" Value="@("ClearAllFilters")">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small" />
                            <span>Clear All</span>
                        </MudStack>
                    </MudSelectItem>
                </MudSelect>
            </MudStack>
        </MudStack>
    </MudCardContent>

    <MudCardActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Save"
                   Disabled="@(!IsDirty || IsLoading)"
                   OnClick="@(() => OnSave.InvokeAsync())">
            @if (IsLoading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
            }
            Save
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                   StartIcon="@Icons.Material.Filled.RestartAlt"
                   Disabled="@(!IsDirty)"
                   OnClick="@(() => OnReset.InvokeAsync())">
            Reset
        </MudButton>
    </MudCardActions>
</MudCard>

@code {
    /// <summary>
    /// The monitor settings working copy to edit. Mutations propagate directly to the parent's working copy.
    /// </summary>
    [Parameter]
    public MonitorSettings? Settings { get; set; }

    /// <summary>
    /// Whether there are unsaved changes.
    /// </summary>
    [Parameter]
    public bool IsDirty { get; set; }

    /// <summary>
    /// Whether a save is in progress.
    /// </summary>
    [Parameter]
    public bool IsLoading { get; set; }

    /// <summary>
    /// Whether advanced (hidden) settings such as Fast Monitor and Log Path are visible.
    /// </summary>
    [Parameter]
    public bool ShowHidden { get; set; }

    /// <summary>
    /// Raised when any setting value changes; used by the parent to recalculate dirty state.
    /// </summary>
    [Parameter]
    public EventCallback OnChanged { get; set; }

    /// <summary>
    /// Raised when the Save button is clicked.
    /// </summary>
    [Parameter]
    public EventCallback OnSave { get; set; }

    /// <summary>
    /// Raised when the Reset button is clicked.
    /// </summary>
    [Parameter]
    public EventCallback OnReset { get; set; }

    /// <summary>
    /// Raised when a preset is selected; carries the full preset MonitorSettings to apply.
    /// </summary>
    [Parameter]
    public EventCallback<MonitorSettings> OnPresetSelected { get; set; }

    /// <summary>
    /// Raised when a quick action is chosen; carries the action key
    /// ("SelectAllDevices", "SelectAllCategories", "SelectAllTypes", or "ClearAllFilters").
    /// </summary>
    [Parameter]
    public EventCallback<string> OnQuickActionTriggered { get; set; }

    private string? _selectedPreset;
    private string? _selectedQuickAction;

    private async Task NotifyChanged() => await OnChanged.InvokeAsync();

    /// <summary>Sets LogMonitor and clears FastMonitor if the two are mutually exclusive.</summary>
    private async Task OnLogMonitorChangedAsync(bool v)
    {
        Settings!.LogMonitor = v;
        if (v) Settings!.FastMonitor = false;
        await NotifyChanged();
    }

    /// <summary>Sets FastMonitor and clears LogMonitor if the two are mutually exclusive.</summary>
    private async Task OnFastMonitorChangedAsync(bool v)
    {
        Settings!.FastMonitor = v;
        if (v) Settings!.LogMonitor = false;
        await NotifyChanged();
    }

    private async Task OnPresetChangedAsync()
    {
        if (_selectedPreset is null) return;
        var preset = _selectedPreset switch
        {
            "Development"    => MonitorPresets.GetDevelopmentPreset(),
            "Production"     => MonitorPresets.GetProductionPreset(),
            "Troubleshooting" => MonitorPresets.GetTroubleshootingPreset(),
            "ProfileDebug"   => MonitorPresets.GetProfileDebugPreset(),
            _                => null
        };
        if (preset is not null)
            await OnPresetSelected.InvokeAsync(preset);
        _selectedPreset = null;
    }

    private async Task OnQuickActionChangedAsync()
    {
        if (_selectedQuickAction is null) return;
        await OnQuickActionTriggered.InvokeAsync(_selectedQuickAction);
        _selectedQuickAction = null;
    }
}
