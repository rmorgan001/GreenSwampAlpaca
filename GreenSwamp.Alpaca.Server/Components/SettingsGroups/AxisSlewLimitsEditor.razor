@using GreenSwamp.Alpaca.Settings.Models

<MudStack Spacing="3">
    <MudTooltip Text="Upper Dec/Alt axis limit in degrees (prevents mount from going too far north/zenith)." Placement="Placement.Right" Arrow="true">
        <MudNumericField T="double" @bind-Value="Device!.AxisUpperLimitY" @bind-Value:after="NotifyChanged"
                         Label="Upper Dec/Alt Axis Limit (°)" Format="F2" Immediate="true" />
    </MudTooltip>
    <MudTooltip Text="Lower Dec/Alt axis limit in degrees." Placement="Placement.Right" Arrow="true">
        <MudNumericField T="double" @bind-Value="Device!.AxisLowerLimitY" @bind-Value:after="NotifyChanged"
                         Label="Lower Dec/Alt Axis Limit (°)" Format="F2" Immediate="true" />
    </MudTooltip>
    <MudTooltip Text="RA/Az axis limit in degrees." Placement="Placement.Right" Arrow="true">
        <MudNumericField T="double" @bind-Value="Device!.AxisLimitX" @bind-Value:after="NotifyChanged"
                         Label="RA/Az Axis Limit (°)" Format="F2" Immediate="true" />
    </MudTooltip>
    <MudTooltip Text="Maximum slew rate in degrees per second." Placement="Placement.Right" Arrow="true">
        <MudNumericField T="double" @bind-Value="Device!.MaximumSlewRate" @bind-Value:after="NotifyChanged"
                         Label="Max Slew Rate (°/s)" Format="F2" Min="0" Immediate="true" />
    </MudTooltip>
    <MudTooltip Text="Axis tracking limit in degrees for the RA/Az axis." Placement="Placement.Right" Arrow="true">
        <MudNumericField T="double" @bind-Value="Device!.AxisTrackingLimit" @bind-Value:after="NotifyChanged"
                         Label="Axis Tracking Limit (°)" Format="F2" Immediate="true" />
    </MudTooltip>
</MudStack>

@code {
    [Parameter] public SkySettings? Device { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    private async Task NotifyChanged() => await OnChanged.InvokeAsync();
}
