@using GreenSwamp.Alpaca.Settings.Models

<MudStack Spacing="3">
    <MudTooltip Text="Equatorial coordinate type returned by the mount (J2000 or JNow)." Placement="Placement.Right" Arrow="true">
        <MudSelect @bind-Value="Device!.EquatorialCoordinateType" @bind-Value:after="NotifyChanged"
                   Label="Equatorial Coordinate Type">
            <MudSelectItem Value="@("Other")">Other</MudSelectItem>
            <MudSelectItem Value="@("Topocentric")">Topocentric (JNow)</MudSelectItem>
            <MudSelectItem Value="@("J2000")">J2000</MudSelectItem>
            <MudSelectItem Value="@("J2050")">J2050</MudSelectItem>
            <MudSelectItem Value="@("B1950")">B1950</MudSelectItem>
        </MudSelect>
    </MudTooltip>
</MudStack>

@code {
    [Parameter] public SkySettings? Device { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    private async Task NotifyChanged() => await OnChanged.InvokeAsync();
}
