@using GreenSwamp.Alpaca.Settings.Models

<MudStack Spacing="3">
    <MudTooltip Text="Human-readable name for this telescope device." Placement="Placement.Right" Arrow="true">
        <MudTextField @bind-Value="Device!.InstrumentName" @bind-Value:after="NotifyChanged"
                      Label="Instrument Name" Immediate="true" />
    </MudTooltip>
    <MudTooltip Text="Description of the instrument shown in Alpaca setup." Placement="Placement.Right" Arrow="true">
        <MudTextField @bind-Value="Device!.InstrumentDescription" @bind-Value:after="NotifyChanged"
                      Label="Instrument Description" Immediate="true" />
    </MudTooltip>
    <MudTooltip Text="Enable this device so it is accessible via Alpaca." Placement="Placement.Right" Arrow="true">
        <MudCheckBox @bind-Value="Device!.Enabled" @bind-Value:after="NotifyChanged"
                     Label="Enabled" Color="Color.Primary" />
    </MudTooltip>
    <MudTooltip Text="Mount driver to use for this device." Placement="Placement.Right" Arrow="true">
        <MudTextField @bind-Value="Device!.Mount" @bind-Value:after="NotifyChanged"
                      Label="Mount" Immediate="true" />
    </MudTooltip>
    <MudTooltip Text="Alignment mode: AltAz, GermanPolar, or Polar." Placement="Placement.Right" Arrow="true">
        <MudSelect @bind-Value="Device!.AlignmentMode" @bind-Value:after="NotifyChanged"
                   Label="Alignment Mode">
            <MudSelectItem Value="@("GermanPolar")">German Equatorial (GEM)</MudSelectItem>
            <MudSelectItem Value="@("Polar")">Polar / Fork</MudSelectItem>
            <MudSelectItem Value="@("AltAz")">Alt-Az</MudSelectItem>
        </MudSelect>
    </MudTooltip>
</MudStack>

@code {
    [Parameter] public SkySettings? Device { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    private async Task NotifyChanged() => await OnChanged.InvokeAsync();
}
