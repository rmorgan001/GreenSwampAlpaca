@using GreenSwamp.Alpaca.Settings.Models

@* Combined editor: Device Identity + Serial Connection + Backlash + Encoders + Custom Gearing *@

<MudExpansionPanels MultiExpansion="true" Elevation="0">

    <MudExpansionPanel Text="Device Information" Icon="@Icons.Material.Filled.Badge" Expanded="true">
        <MudStack Spacing="3">
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Enable this device so it is accessible via Alpaca." Placement="Placement.Right" Arrow="true">
                <MudCheckBox @bind-Value="Device!.Enabled" @bind-Value:after="NotifyChanged"
                             Label="Enabled for Alpaca" Color="Color.Primary" />
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Human-readable name for this telescope device, returned as the ASCOM Name property." Placement="Placement.Right" Arrow="true">
                <MudTextField @bind-Value="Device!.DeviceName" @bind-Value:after="NotifyChanged"
                              Label="Device Name" Immediate="true" />
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Description of the device shown in Alpaca setup." Placement="Placement.Right" Arrow="true">
                <MudTextField @bind-Value="Device!.DeviceDescription" @bind-Value:after="NotifyChanged"
                              Label="Description" Immediate="true" />
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Mount driver to use for this device." Placement="Placement.Right" Arrow="true">
                <MudTextField @bind-Value="Device!.Mount" @bind-Value:after="NotifyChanged"
                              Label="Mount Type" Immediate="true" />
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Alignment mode: AltAz, GermanPolar, or Polar." Placement="Placement.Right" Arrow="true">
                <MudSelect @bind-Value="Device!.AlignmentMode" @bind-Value:after="NotifyChanged"
                           Label="Alignment Mode">
                    <MudSelectItem Value="@("GermanPolar")">German Equatorial (GEM)</MudSelectItem>
                    <MudSelectItem Value="@("Polar")">Polar / Fork</MudSelectItem>
                    <MudSelectItem Value="@("AltAz")">Alt-Az</MudSelectItem>
                </MudSelect>
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="The primary side of the pier for polar-aligned GEM mounts." Placement="Placement.Right" Arrow="true">
                <MudSelect @bind-Value="Device!.PolarMode" @bind-Value:after="NotifyChanged"
                           Label="Polar Primary Side">
                    <MudSelectItem Value="@("Left")">Left</MudSelectItem>
                    <MudSelectItem Value="@("Right")">Right</MudSelectItem>
                </MudSelect>
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Equatorial coordinate type returned by the mount (J2000 or JNow)." Placement="Placement.Right" Arrow="true">
                <MudSelect @bind-Value="Device!.EquatorialCoordinateType" @bind-Value:after="NotifyChanged"
                           Label="Equatorial Coordinate Type">
                    <MudSelectItem Value="@("Other")">Other</MudSelectItem>
                    <MudSelectItem Value="@("Topocentric")">Topocentric (JNow)</MudSelectItem>
                    <MudSelectItem Value="@("J2000")">J2000</MudSelectItem>
                    <MudSelectItem Value="@("J2050")">J2050</MudSelectItem>
                    <MudSelectItem Value="@("B1950")">B1950</MudSelectItem>
                </MudSelect>
            </MudTooltip>
        </MudStack>
    </MudExpansionPanel>

    <MudExpansionPanel Text="Serial Connection" Icon="@Icons.Material.Filled.Cable" Expanded="true">
        <MudStack Spacing="3">
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Serial port name, e.g. COM3." Placement="Placement.Right" Arrow="true">
                <MudTextField @bind-Value="Device!.Port" @bind-Value:after="NotifyChanged"
                              Label="Port" Immediate="true" />
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Serial baud rate." Placement="Placement.Right" Arrow="true">
                <MudNumericField T="int" @bind-Value="Device!.BaudRate" @bind-Value:after="NotifyChanged"
                                 Label="Baud Rate" Immediate="true" />
            </MudTooltip>
            @if (ShowHidden)
            {
                <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Number of data bits." Placement="Placement.Right" Arrow="true">
                    <MudNumericField T="int" @bind-Value="Device!.DataBits" @bind-Value:after="NotifyChanged"
                                     Label="Data Bits" Min="5" Max="8" Immediate="true" />
                </MudTooltip>
                <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Handshake protocol (None, XOnXOff, RequestToSend, etc.)." Placement="Placement.Right" Arrow="true">
                    <MudTextField @bind-Value="Device!.Handshake" @bind-Value:after="NotifyChanged"
                                  Label="Handshake" Immediate="true" />
                </MudTooltip>
                <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Read timeout in milliseconds." Placement="Placement.Right" Arrow="true">
                    <MudNumericField T="int" @bind-Value="Device!.ReadTimeout" @bind-Value:after="NotifyChanged"
                                     Label="Read Timeout (ms)" Immediate="true" />
                </MudTooltip>
                <MudCheckBox @bind-Value="Device!.DTREnable" @bind-Value:after="NotifyChanged"
                             Label="DTR Enable" Color="Color.Primary" />
                <MudCheckBox @bind-Value="Device!.RTSEnable" @bind-Value:after="NotifyChanged"
                             Label="RTS Enable" Color="Color.Primary" />
            }
        </MudStack>
    </MudExpansionPanel>

    <MudExpansionPanel Text="Mount Hardware" Icon="@Icons.Material.Filled.Bolt">
        <MudStack Spacing="3">
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Enable advanced commands for mount control." Placement="Placement.Right" Arrow="true">
                <MudCheckBox @bind-Value="Device!.AllowAdvancedCommandSet" @bind-Value:after="NotifyChanged"
                             Label="Aloow Advanced Commands" Color="Color.Primary" />
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Enable absolute encoder feedback for the mount axes." Placement="Placement.Right" Arrow="true">
                <MudCheckBox @bind-Value="Device!.EncodersOn" @bind-Value:after="NotifyChanged"
                             Label="Encoders Enabled" Color="Color.Primary" />
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Maximum slew rate in degrees per second." Placement="Placement.Right" Arrow="true">
                <MudNumericField T="double" @bind-Value="Device!.MaximumSlewRate" @bind-Value:after="NotifyChanged"
                                 Label="Max Slew Rate (°/s)" Format="F2" Min="0" Immediate="true" />
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="RA axis backlash compensation in motor steps." Placement="Placement.Right" Arrow="true">
                <MudNumericField T="int" @bind-Value="Device!.RaBacklash" @bind-Value:after="NotifyChanged"
                                 Label="RA Backlash (steps)" Min="0" Immediate="true" />
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Dec axis backlash compensation in motor steps." Placement="Placement.Right" Arrow="true">
                <MudNumericField T="int" @bind-Value="Device!.DecBacklash" @bind-Value:after="NotifyChanged"
                                 Label="Dec Backlash (steps)" Min="0" Immediate="true" />
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Polar scope LED brightness level (0–255)." Placement="Placement.Right" Arrow="true">
                <MudNumericField T="int" @bind-Value="Device!.PolarLedLevel" @bind-Value:after="NotifyChanged"
                                 Label="Polar LED Level" Min="0" Max="255" Immediate="true" />
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Enable full current mode on the motor drivers." Placement="Placement.Right" Arrow="true">
                <MudCheckBox @bind-Value="Device!.FullCurrent" @bind-Value:after="NotifyChanged"
                             Label="Full Current" Color="Color.Primary" />
            </MudTooltip>
        </MudStack>
    </MudExpansionPanel>

    <MudExpansionPanel Text="Custom Gearing" Icon="@Icons.Material.Filled.Settings">
        <MudStack Spacing="3">
            <MudCheckBox @bind-Value="Device!.CustomGearing" @bind-Value:after="NotifyChanged"
                         Label="Enable Custom Gearing" Color="Color.Primary" />
            <MudText Typo="Typo.subtitle2" Class="mt-2">RA Axis</MudText>
            <MudNumericField T="int" @bind-Value="Device!.CustomRa360Steps" @bind-Value:after="NotifyChanged"
                             Label="RA 360° Steps" Immediate="true" Disabled="@(!Device!.CustomGearing)" />
            <MudNumericField T="int" @bind-Value="Device!.CustomRaWormTeeth" @bind-Value:after="NotifyChanged"
                             Label="RA Worm Teeth" Immediate="true" Disabled="@(!Device!.CustomGearing)" />
            <MudNumericField T="int" @bind-Value="Device!.CustomRaTrackingOffset" @bind-Value:after="NotifyChanged"
                             Label="RA Tracking Offset" Immediate="true" Disabled="@(!Device!.CustomGearing)" />
            <MudText Typo="Typo.subtitle2" Class="mt-2">Dec Axis</MudText>
            <MudNumericField T="int" @bind-Value="Device!.CustomDec360Steps" @bind-Value:after="NotifyChanged"
                             Label="Dec 360° Steps" Immediate="true" Disabled="@(!Device!.CustomGearing)" />
            <MudNumericField T="int" @bind-Value="Device!.CustomDecWormTeeth" @bind-Value:after="NotifyChanged"
                             Label="Dec Worm Teeth" Immediate="true" Disabled="@(!Device!.CustomGearing)" />
            <MudNumericField T="int" @bind-Value="Device!.CustomDecTrackingOffset" @bind-Value:after="NotifyChanged"
                             Label="Dec Tracking Offset" Immediate="true" Disabled="@(!Device!.CustomGearing)" />
        </MudStack>
    </MudExpansionPanel>

</MudExpansionPanels>

@code {
    [Parameter] public SkySettings? Device { get; set; }
    [Parameter] public bool ShowHidden { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    private async Task NotifyChanged() => await OnChanged.InvokeAsync();
}
