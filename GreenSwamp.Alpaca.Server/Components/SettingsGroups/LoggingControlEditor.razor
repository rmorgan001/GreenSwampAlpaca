@using GreenSwamp.Alpaca.Settings.Models

<MudStack Spacing="3">
    <MudTooltip Text="Must be ON for any log files to be written." Placement="Placement.Right" Arrow="true" Inline="false">
        <MudCheckBox @bind-Value="Settings!.StartMonitor" @bind-Value:after="NotifyChanged" Label="Auto-start Monitor" Color="Color.Primary" />
    </MudTooltip>
    <MudTooltip Text="Writes monitor output to GSMonitorLog*.txt. Mutually exclusive with Fast Monitor." Placement="Placement.Right" Arrow="true" Inline="false">
        <MudCheckBox @bind-Value="Settings!.LogMonitor" @bind-Value:after="NotifyChanged" Label="Log Monitor Messages" Color="Color.Primary" />
    </MudTooltip>
    <MudTooltip Text="1000-record ring buffer — lower overhead than Log Monitor. Mutually exclusive with Log Monitor." Placement="Placement.Right" Arrow="true" Inline="false">
        <MudCheckBox @bind-Value="Settings!.FastMonitor" @bind-Value:after="NotifyChanged" Label="Fast Monitor (Buffer)" Color="Color.Primary" />
    </MudTooltip>
    <MudTooltip Text="Writes session data to GSSessionLog*.txt." Placement="Placement.Right" Arrow="true" Inline="false">
        <MudCheckBox @bind-Value="Settings!.LogSession" @bind-Value:after="NotifyChanged" Label="Log Session" Color="Color.Primary" />
    </MudTooltip>
    <MudTooltip Text="Writes charting data to GSChartingLog*.txt." Placement="Placement.Right" Arrow="true" Inline="false">
        <MudCheckBox @bind-Value="Settings!.LogCharting" @bind-Value:after="NotifyChanged" Label="Log Charting" Color="Color.Primary" />
    </MudTooltip>
    @if (ShowHidden)
    {
        <MudTooltip Inline="false" RootStyle="max-width:260px" Text="UI language code, e.g. en-US." Placement="Placement.Right" Arrow="true">
            <MudTextField @bind-Value="Settings!.Language" @bind-Value:after="NotifyChanged"
                          Label="Language" Immediate="true" />
        </MudTooltip>
        <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Directory path where log files are written. Leave empty for the default location (%USERPROFILE%\Documents\GSServer)." Placement="Placement.Right" Arrow="true">
            <MudTextField @bind-Value="Settings!.LogPath" @bind-Value:after="NotifyChanged"
                          Label="Log Path" Immediate="true" />
        </MudTooltip>
    }
</MudStack>

@code {
    [Parameter] public MonitorSettings? Settings { get; set; }
    [Parameter] public bool ShowHidden { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    private async Task NotifyChanged() => await OnChanged.InvokeAsync();
}
