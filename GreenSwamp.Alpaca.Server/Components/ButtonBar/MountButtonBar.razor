@using ASCOM.Alpaca
@using GreenSwamp.Alpaca.MountControl
@using GreenSwamp.Alpaca.Server.Components
@using GreenSwamp.Alpaca.Server.Components.ButtonBar
@using GreenSwamp.Alpaca.Server.Components.Dialogs
@using GreenSwamp.Alpaca.Server.Models
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudStack Row="@(!Vertical)" Spacing="2" AlignItems="AlignItems.Center">

    @if (ShowPrimaryButtons)
    {
        @* -- Park ----------------------------------------------------------- *@
        <MudTooltip Text="@(State.AtPark ? "Unpark the mount" : "Park the mount at the selected position")"
                    Placement="Placement.Top" Arrow="true">
            <MudIconButton Variant="Variant.Text"
                           Icon="@Icons.Material.Filled.LocalParking"
                           Color="@(State.AtPark ? Color.Warning : Color.Primary)"
                           Size="Size.Large"
                           Disabled="@(!IsConnected || (State.AtPark
                                                                                ? !(Mount?.Settings.CanUnPark ?? false)
                                                                                : !(Mount?.Settings.CanPark ?? false)))"
                           OnClick="OnParkClickAsync">
            </MudIconButton>
        </MudTooltip>

        @* -- Home ----------------------------------------------------------- *@
        <MudTooltip Text="Slew to the home position" Placement="Placement.Top" Arrow="true">
            <MudIconButton Color="Color.Primary" Variant="Variant.Text"
                           Icon="@Icons.Material.Filled.Home"
                           Size="Size.Large"
                           Disabled="@(!IsConnected || State.AtPark || !(Mount?.Settings.CanFindHome ?? false))"
                           OnClick="OnHomeClickAsync" />
        </MudTooltip>

        @* -- Tracking ---------------------------------------------------- *@
        <MudTooltip Text="@(State.Tracking ? "Turn tracking off" : "Turn tracking on")"
                    Placement="Placement.Top" Arrow="true">
            <MudIconButton Color="Color.Primary" Variant="Variant.Text"
                           Icon="@Icons.Material.Filled.TrackChanges"
                           Size="Size.Large"
                           Disabled="@(!IsConnected)"
                           OnClick="OnTrackingClickAsync">
            </MudIconButton>
        </MudTooltip>

        @* -- ReSync ------------------------------------------------------ *@
        <MudTooltip Text="Resync axes to a reference position" Placement="Placement.Top" Arrow="true">
            <MudIconButton Variant="Variant.Text" Color="Color.Primary"
                           Icon="@Icons.Material.Filled.SettingsEthernet"
                           Size="Size.Large"
                           Disabled="@(!IsConnected || State.Slewing)"
                           OnClick="OnReSyncClickAsync">
            </MudIconButton>
        </MudTooltip>

        @* -- Flip SOP (GEM only) ----------------------------------------- *@
        @if (State.IsGermanPolarMode)
        {
            <MudTooltip Text="Flip the telescope to the opposite pier side" Placement="Placement.Top" Arrow="true">
                <MudIconButton Variant="Variant.Text" Color="Color.Primary"
                               Icon="@Icons.Material.Filled.FlipCameraAndroid"
                               Size="Size.Large"
                               Disabled="@(!IsConnected || State.Slewing)"
                               OnClick="OnFlipSopClickAsync">
                </MudIconButton>
            </MudTooltip>
        }

        @* -- AutoHome ---------------------------------------------------- *@
        <MudTooltip Text="Search for home sensor and reset axes" Placement="Placement.Top" Arrow="true">
            <MudIconButton Variant="Variant.Text"
                       Color="@(State.IsAutoHomeRunning ? Color.Warning : Color.Primary)"
                       Icon="@HomeSearchIcon"
                       Size="Size.Large"
                       Disabled="@(!IsConnected || State.AtPark)"
                       OnClick="OnAutoHomeClickAsync">
                @(State.IsAutoHomeRunning ? "AutoHome…" : "AutoHome")
            </MudIconButton>
        </MudTooltip>

        @* -- Limits ------------------------------------------------------ *@
        <MudTooltip Text="@(State.LimitsOn ? "Disable flip angle limits" : "Enable flip angle limits")"
                    Placement="Placement.Top" Arrow="true">
            <MudIconButton Variant="Variant.Text"
                       Color="Color.Primary"
                       Icon="@LimitsOnIcon"
                       Size="Size.Large"
                       Disabled="@(!IsConnected)"
                       OnClick="OnLimitsClickAsync">
            </MudIconButton>
        </MudTooltip>

        @* -- Voice ----------------------------------------------------------- *@
        <MudTooltip Text="@(!State.VoiceActive ? "Enable voice announcements" : "Disable voice announcements")" Placement="Placement.Top" Arrow="true">
            <MudIconButton Color="Color.Primary" Variant="Variant.Text"
                           Icon="@(!State.VoiceActive ? Icons.Material.Filled.RecordVoiceOver : Icons.Material.Filled.VoiceOverOff)"
                           Size="Size.Large"
                           OnClick="OnVoiceActiveSetAsync" />
        </MudTooltip>
    }

</MudStack>

@if (ShowStopButton)
{
    @* -- Stop -------------------------------------------------------- *@
    <MudTooltip Text="Emergency stop all axis motion" Placement="Placement.Top" Arrow="true">
        <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                   Disabled="@(!State.HasEverBeenConnected && !IsConnected)"
                   OnClick="OnStopClickAsync">
            Stop
        </MudButton>
    </MudTooltip>
}
