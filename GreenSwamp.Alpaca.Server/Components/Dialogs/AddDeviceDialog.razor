@using GreenSwamp.Alpaca.Settings.Models
@using MudBlazor

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.AddCircleOutline" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Add Telescope Device</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="4" Class="mt-2">
            <MudTextField @bind-Value="_deviceName"
                          Label="Device Name"
                          Placeholder="e.g. EQ6-R Pro"
                          Required="true"
                          RequiredError="Device name is required"
                          Immediate="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.DeviceHub" />

            <MudSelect @bind-Value="_mountType"
                       Label="Mount Type"
                       HelperText="Applies Simulator or SkyWatcher default settings">
                <MudSelectItem Value="MountType.Simulator">
                    No physical mount, use for testing and simulation
                </MudSelectItem>
                <MudSelectItem Value="MountType.SkyWatcher">
                    Physical mount, must support SkyWatcher / Synta commands
                </MudSelectItem>
            </MudSelect>

            <MudSelect @bind-Value="_alignmentMode"
                       Label="Alignment Mode"
                       HelperText="Applies alignment mode specific default settings">
                <MudSelectItem Value="AlignmentMode.GermanPolar">
                    German Equatorial (GEM) — counterweight, meridian flip
                </MudSelectItem>
                <MudSelectItem Value="AlignmentMode.Polar">
                    Polar / Fork — fork equatorial, no meridian flip
                </MudSelectItem>
                <MudSelectItem Value="AlignmentMode.AltAz">
                    Alt-Azimuth — altitude / azimuth axes
                </MudSelectItem>
            </MudSelect>

            <MudAlert Severity="Severity.Info" Dense="true">
                All other settings can be configured in the device's
                <strong>Mount Configuration</strong> group after the device is added.
            </MudAlert>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   Disabled="@string.IsNullOrWhiteSpace(_deviceName)"
                   OnClick="Confirm"
                   StartIcon="@Icons.Material.Filled.Add">
            Add Device
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    private string _deviceName = string.Empty;
    private AlignmentMode _alignmentMode = AlignmentMode.GermanPolar;
    private MountType _mountType = MountType.Simulator;

    private void Confirm()
    {
        if (string.IsNullOrWhiteSpace(_deviceName)) return;
        MudDialog.Close(DialogResult.Ok((_deviceName.Trim(), _mountType, _alignmentMode)));
    }

    private void Cancel() => MudDialog.Cancel();
}
