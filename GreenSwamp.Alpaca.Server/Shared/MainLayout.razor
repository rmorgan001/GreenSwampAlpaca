@using System.Globalization
@inherits LayoutComponentBase

<MudThemeProvider Theme="@GsTheme.Instance" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<GlobalNotificationsHost />

<MudLayout>
    <MudAppBar Elevation="0" Dense="true"
               Style="background-color:var(--gs-bg-sidebar); border-bottom:1px solid var(--gs-divider);">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit"
                       Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6" Style="font-weight:300; letter-spacing:0.01em; font-size:16px;">
            <span style="font-weight:700; color:var(--gs-accent-500);">GS</span>Alpaca
        </MudText>

        <!-- Displays current Date and Time -->
        <MudSpacer />
        <MudText Typo="Typo.h6" Color="Color.Primary">@CurrentDateTimeString</MudText>

        <MudSpacer />
        <MudLink Href="https://greenswamp.org/" Target="_blank" Color="Color.Inherit"
                 Typo="Typo.caption" Style="opacity:0.6;">About</MudLink>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="0" Variant="DrawerVariant.Responsive"
               ClipMode="DrawerClipMode.Always"
               Style="background-color:var(--gs-bg-sidebar); border-right:1px solid rgba(var(--gs-accent-500-rgb),0.2);">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private string CurrentDateTimeString { get; set; } = string.Empty;
    private Timer? _timer;

    protected override void OnInitialized()
    {
        // Update immediately on load
        UpdateDateTime();

        // Create a timer that ticks every 200 ms
        _timer = new Timer(Callback, null, TimeSpan.Zero, TimeSpan.FromMilliseconds(200));
    }

    private void UpdateDateTime()
    {
        // Customise the date and time format string here
        CurrentDateTimeString = DateTime.Now.ToString("dd MMM yyyy  HH:mm:ss.ff", CultureInfo.CurrentCulture);
        StateHasChanged(); // Refresh the UI
    }

    private void Callback(object? state)
    {
        InvokeAsync(() => UpdateDateTime());
    }
    public void Dispose()
    {
        _timer?.Dispose();
    }
}
