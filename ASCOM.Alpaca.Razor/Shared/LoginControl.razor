@using Microsoft.AspNetCore.Components.Authorization

@inject NavigationManager MyNavigationManager

<AuthorizeView>
    <Authorized>
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudText Typo="Typo.body2">
                Logged in as: <strong>@context.User.Identity?.Name</strong>
            </MudText>
            <MudButton Href="/logout?returnUrl=/" Target="_top"
                       Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small">
                Logout
            </MudButton>
        </MudStack>
    </Authorized>
    <NotAuthorized>
        <form action="@($"/login?url={Return}")" method="post">
            <MudStack Spacing="3">
                <MudTextField T="string" Label="Username" Variant="Variant.Outlined"
                              name="username" autocomplete="username" />
                <MudTextField T="string" Label="Password" Variant="Variant.Outlined"
                              InputType="InputType.Password"
                              name="password" autocomplete="current-password" />
                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled"
                           Color="Color.Primary" FullWidth="true">
                    Login
                </MudButton>
            </MudStack>
        </form>
    </NotAuthorized>
</AuthorizeView>

@code {
    private string Return => new Uri(MyNavigationManager.Uri).LocalPath;
}
