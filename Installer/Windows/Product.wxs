<?xml version="1.0" encoding="utf-8"?>
<!--
  $(Version), $(UpgradeCode), and $(PublishDir) are WiX preprocessor variables.
  They are defined via <DefineConstants> in GreenSwamp.Alpaca.Installer.wixproj
  so that CI can override them with -p:UpgradeCode=... -p:PublishDir=... etc.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
	 xmlns:fw="http://wixtoolset.org/schemas/v4/wxs/firewall">

  <Package Name="GreenSwamp Alpaca Server"
		   Manufacturer="Principia4834"
		   Version="$(Version)"
		   UpgradeCode="$(UpgradeCode)"
		   Compressed="true">

	<MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

	<MediaTemplate EmbedCab="true" />

	<!-- Installer UI
		 In WiX v7, the built-in dialog sets are arch-specific.
		 The file-scoped "WixUI_Minimal" cannot be referenced directly (WIX0094).
		 Use the public arch-qualified variant matching the installer platform.
	-->
	<WixVariable Id="WixUILicenseRtf" Value="Resources\License.rtf" />
	<WixVariable Id="WixUIBannerBmp"  Value="Resources\banner.bmp" />
	<WixVariable Id="WixUIDialogBmp"  Value="Resources\dialog.bmp" />
	<Icon Id="greenswamp2.ico" SourceFile="Resources\greenswamp2.ico"/>
	<Property Id="ARPPRODUCTICON" Value="greenswamp2.ico" />	
	
	<?if $(sys.BUILDARCH) = x64 ?>
	<UIRef Id="WixUI_Minimal_X64" />
	<?elseif $(sys.BUILDARCH) = x86 ?>
	<UIRef Id="WixUI_Minimal_X86" />
	<?elseif $(sys.BUILDARCH) = arm64 ?>
	<UIRef Id="WixUI_Minimal_A64" />
	<?else ?>
	<UIRef Id="WixUI_Minimal_X64" />
	<?endif ?>

	<!-- Install directory structure -->
	<StandardDirectory Id="ProgramFiles6432Folder">
	  <Directory Id="MANUFACTURERDIR" Name="GreenSwamp">
		<Directory Id="INSTALLDIR" Name="Alpaca Server" />
	  </Directory>
	</StandardDirectory>

	<StandardDirectory Id="ProgramMenuFolder">
	  <Directory Id="STARTMENUFOLDER" Name="GreenSwamp Alpaca Server" />
	</StandardDirectory>

	<!--
	  HeatWave auto-harvesting: <Files Include="..." /> generates a <Component> and <File>
	  for every file under PublishDir at build time. No manual component authoring needed.
	-->
	<ComponentGroup Id="ProductComponents" Directory="INSTALLDIR">
	  <Files Include="$(PublishDir)**">
		<Exclude Files="$(PublishDir)GreenSwamp.Alpaca.Server.exe" />
	  </Files>
	</ComponentGroup>

	<!-- Windows Service registration -->
	<!-- Explicit GUID required: no file KeyPath (WIX0230) -->
	<Component Id="ServiceComponent" Directory="INSTALLDIR" Guid="818DF99D-267F-4FFA-B3A7-E5F578372A8A">
	  <File Id="ServiceExe"
			Name="GreenSwamp.Alpaca.Server.exe"
			Source="$(PublishDir)GreenSwamp.Alpaca.Server.exe"
			KeyPath="yes" />
	  <ServiceInstall
		Id="GreenSwampAlpacaService"
		Name="GreenSwampAlpacaServer"
		DisplayName="GreenSwamp Alpaca Server"
		Description="ASCOM Alpaca telescope mount control server"
		Type="ownProcess"
		Start="auto"
		ErrorControl="normal"
		Account="LocalSystem" />
	  <ServiceControl
		Id="StartGreenSwampAlpacaService"
		Name="GreenSwampAlpacaServer"
		Start="install"
		Stop="both"
		Remove="uninstall"
		Wait="yes" />
	</Component>

	<!-- Firewall exception for the Alpaca server port -->
	<!-- Explicit GUID required: no file KeyPath (WIX0230) -->
	<Component Id="FirewallComponent" Directory="INSTALLDIR" Guid="C4C0CD8D-200A-4035-9DB6-ABB9EFCBCEC3">
	  <fw:FirewallException
		Id="AlpacaServerFirewall"
		Name="GreenSwamp Alpaca Server"
		Port="31426"
		Protocol="tcp"
		Scope="any"
		IgnoreFailure="yes" />
	</Component>

	<!-- Start-menu shortcut that opens the management UI in the default browser.
		 WiX Shortcut/@Target must be a file path, not a URL (ICE03), so we
		 install a Windows .url internet-shortcut file instead.
		 ICE38 requires a RegistryValue KeyPath for components in the user profile. -->
	<Component Id="ShortcutComponent" Directory="STARTMENUFOLDER" Guid="90A54B68-991F-4BBA-886B-4CD9954C0BA5">
	  <File Id="ManagementUIShortcutFile"
			Name="GreenSwamp Alpaca Server.url"
			Source="GreenSwampAlpacaServer.url" />
	  <RemoveFolder Id="RemoveStartMenu" Directory="STARTMENUFOLDER" On="uninstall" />
	  <RegistryValue Root="HKCU"
					 Key="Software\GreenSwamp\AlpacaServer"
					 Name="installed"
					 Type="integer"
					 Value="1"
					 KeyPath="yes" />
	</Component>

	<!-- Root feature — everything is required -->
	<Feature Id="ProductFeature" Title="GreenSwamp Alpaca Server" Level="1">
	  <ComponentGroupRef Id="ProductComponents" />
	  <ComponentRef Id="ServiceComponent" />
	  <ComponentRef Id="FirewallComponent" />
	  <ComponentRef Id="ShortcutComponent" />
	</Feature>

  </Package>
</Wix>
