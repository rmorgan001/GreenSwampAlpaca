  </ItemGroup>

  <ItemGroup>
    <None Update="Properties\Monitor.settings">
      <Generator>SettingsSingleFileGenerator</Generator>
      <LastGenOutput>Monitor.Designer.cs</LastGenOutput>
    </None>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Update="MinVer" Version="7.0.0" />
  </ItemGroup>

</Project>
