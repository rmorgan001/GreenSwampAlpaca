# Shell scripts must always use LF, never CRLF
*.sh text eol=lf
Installer/Linux/**/*.sh text eol=lf
Installer/Linux/debian/* text eol=lf
Installer/Linux/systemd/* text eol=lf

# Debian maintainer scripts
Installer/Linux/debian/postinst text eol=lf
Installer/Linux/debian/prerm text eol=lf
Installer/Linux/debian/postrm text eol=lf